@page "/"

<PageTitle>Home</PageTitle>

<div class="hero">
    <div class="hero-text">
        <h1>Elektronická servisná knižka</h1>
        <p>
            Moderný systém pre evidenciu servisných úkonov vozidiel.
            Prehľad, bezpečnosť a dostupnosť z každého zariadenia.
        </p>

        <div class="hero-buttons">
            <a href="/login" class="btn primary">Prihlásiť sa</a>
            <a href="/register" class="btn secondary">Registrácia</a>
        </div>
    </div>
</div>

<div class="features">
    <div class="card">
        <h3>Majiteľ vozidla</h3>
        <p>
            Prehľad servisnej histórie, export do PDF,
            sledovanie údržby vozidla.
        </p>
    </div>

    <div class="card">
        <h3>Autoservis</h3>
        <p>
            Zápis servisných úkonov, správa vozidiel,
            prístup len k povoleným záznamom.
        </p>
    </div>

    <div class="card">
        <h3>Administrátor</h3>
        <p>
            Správa používateľov, oprávnení a systémových nastavení.
        </p>
    </div>
</div>

