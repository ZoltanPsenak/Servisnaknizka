@page "/"
@layout EmptyLayout
@rendermode InteractiveServer

<PageTitle>Domov - Servisná knižka</PageTitle>

<div class="lp">
    <!-- NAV -->
    <nav class="lp-nav">
        <div class="lp-wrap">
            <a href="/" class="lp-logo">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                <span>Servisná Knižka</span>
            </a>
            <button class="lp-burger" @onclick="() => menuOpen = !menuOpen" aria-label="Menu">
                @if (menuOpen)
                {
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                }
                else
                {
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/></svg>
                }
            </button>
            <div class="lp-links @(menuOpen ? "open" : "")">
                <a href="#funkcie" @onclick="() => menuOpen = false">Funkcie</a>
                <a href="#o-nas" @onclick="() => menuOpen = false">O aplikácii</a>
                <a href="/login" class="lp-cta-link">Prihlásiť sa</a>
            </div>
        </div>
    </nav>

    <!-- HERO -->
    <section class="lp-hero">
        <div class="lp-wrap lp-hero-inner">
            <span class="lp-pill">Digitálna servisná knižka</span>
            <h1>Všetka údržba vášho auta<br/><em>na jednom mieste</em></h1>
            <p>Prehľadná história servisu, automatické pripomienky na STK, emisie a poistenie. Prístupné z&nbsp;mobilu aj&nbsp;počítača.</p>
            <div class="lp-hero-btns">
                <a href="/register" class="lp-btn lp-btn-w">Vytvoriť účet zadarmo</a>
                <a href="/login" class="lp-btn lp-btn-o">Prihlásiť sa</a>
            </div>
        </div>
    </section>

    <!-- FEATURES -->
    <section id="funkcie" class="lp-features">
        <div class="lp-wrap">
            <h2>Čo všetko zvládne?</h2>
            <div class="lp-grid">
                <div class="lp-card">
                    <div class="lp-icon blue">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="2"/></svg>
                    </div>
                    <h3>História servisu</h3>
                    <p>Kompletný prehľad všetkých opráv, výmen a údržby. Nič sa nestratí.</p>
                </div>
                <div class="lp-card">
                    <div class="lp-icon purple">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                    </div>
                    <h3>Pripomienky</h3>
                    <p>Upozornenia na STK, emisnú kontrolu, poistenie a pravidelný servis.</p>
                </div>
                <div class="lp-card">
                    <div class="lp-icon green">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    </div>
                    <h3>Export do PDF</h3>
                    <p>Profesionálny report histórie vozidla na pár kliknutí.</p>
                </div>
                <div class="lp-card">
                    <div class="lp-icon orange">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </div>
                    <h3>Pre autoservisy</h3>
                    <p>Správa klientskych vozidiel a jednoduchý prístup k servisným záznamom.</p>
                </div>
                <div class="lp-card">
                    <div class="lp-icon red">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    </div>
                    <h3>Bezpečné dáta</h3>
                    <p>Šifrovaná komunikácia, zálohy a dvojfaktorové overenie.</p>
                </div>
                <div class="lp-card">
                    <div class="lp-icon cyan">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
                    </div>
                    <h3>Prevod vozidla</h3>
                    <p>Jednoduché odovzdanie vozidla novému majiteľovi vrátane celej histórie.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- HOW IT WORKS -->
    <section id="o-nas" class="lp-how">
        <div class="lp-wrap">
            <h2>Ako to funguje?</h2>
            <div class="lp-steps">
                <div class="lp-step">
                    <div class="lp-step-num">1</div>
                    <h3>Zaregistrujte sa</h3>
                    <p>Vytvorte si bezplatný účet za pár sekúnd.</p>
                </div>
                <div class="lp-step">
                    <div class="lp-step-num">2</div>
                    <h3>Pridajte vozidlo</h3>
                    <p>Zadajte údaje o vozidle — značka, model, VIN, ŠPZ.</p>
                </div>
                <div class="lp-step">
                    <div class="lp-step-num">3</div>
                    <h3>Evidujte servisy</h3>
                    <p>Pridávajte záznamy a nechajte si pripomínať termíny.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="lp-cta">
        <div class="lp-wrap lp-cta-inner">
            <h2>Začnite ešte dnes</h2>
            <p>Bezplatná registrácia, bez záväzkov.</p>
            <a href="/register" class="lp-btn lp-btn-w">Vytvoriť účet</a>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="lp-footer">
        <div class="lp-wrap">
            <p>&copy; 2026 Servisná Knižka — Všetky práva vyhradené</p>
        </div>
    </footer>
</div>

<style>
    /* ===== RESET & BASE ===== */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    .lp {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        color: #1e293b;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
    }

    .lp-wrap {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 20px;
    }

    /* ===== NAV ===== */
    .lp-nav {
        position: fixed; top: 0; left: 0; right: 0;
        z-index: 100;
        background: rgba(255,255,255,0.92);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid #f1f5f9;
    }

    .lp-nav .lp-wrap {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 60px;
    }

    .lp-logo {
        display: flex; align-items: center; gap: 10px;
        text-decoration: none; color: #0f172a;
        font-weight: 800; font-size: 17px;
    }

    .lp-logo svg { color: #2563eb; }

    .lp-links {
        display: flex; align-items: center; gap: 28px;
    }

    .lp-links a {
        text-decoration: none; font-size: 14px; font-weight: 500;
        color: #64748b; transition: color 0.2s;
    }

    .lp-links a:hover { color: #0f172a; }

    .lp-cta-link {
        background: #2563eb !important; color: white !important;
        padding: 8px 20px; border-radius: 8px; font-weight: 600 !important;
        transition: background 0.2s !important;
    }

    .lp-cta-link:hover { background: #1d4ed8 !important; }

    .lp-burger {
        display: none; background: none; border: none;
        cursor: pointer; padding: 6px; color: #334155; border-radius: 6px;
    }

    .lp-burger:hover { background: #f1f5f9; }

    /* ===== HERO ===== */
    .lp-hero {
        padding: 140px 0 100px;
        background: linear-gradient(160deg, #1e3a8a 0%, #2563eb 50%, #0ea5e9 100%);
        text-align: center;
        color: white;
    }

    .lp-hero-inner { max-width: 680px; }

    .lp-pill {
        display: inline-block;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(255,255,255,0.25);
        padding: 6px 18px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 28px;
    }

    .lp-hero h1 {
        font-size: 48px;
        font-weight: 900;
        line-height: 1.15;
        margin-bottom: 20px;
        letter-spacing: -0.03em;
    }

    .lp-hero h1 em {
        font-style: normal;
        opacity: 0.85;
    }

    .lp-hero p {
        font-size: 18px;
        line-height: 1.7;
        opacity: 0.9;
        margin-bottom: 36px;
        max-width: 520px;
        margin-left: auto;
        margin-right: auto;
    }

    .lp-hero-btns {
        display: flex; gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .lp-btn {
        display: inline-flex; align-items: center; justify-content: center;
        padding: 14px 28px;
        border-radius: 10px;
        font-size: 15px; font-weight: 700;
        text-decoration: none;
        transition: transform 0.15s, box-shadow 0.2s;
    }

    .lp-btn:hover { transform: translateY(-2px); }

    .lp-btn-w {
        background: white; color: #1e3a8a;
        box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    }

    .lp-btn-o {
        background: transparent; color: white;
        border: 2px solid rgba(255,255,255,0.4);
    }

    .lp-btn-o:hover { background: rgba(255,255,255,0.1); }

    /* ===== FEATURES ===== */
    .lp-features {
        padding: 96px 0;
        background: #f8fafc;
    }

    .lp-features h2, .lp-how h2 {
        text-align: center;
        font-size: 32px;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 48px;
        letter-spacing: -0.02em;
    }

    .lp-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    .lp-card {
        background: white;
        border-radius: 14px;
        padding: 28px 24px;
        border: 1px solid #e2e8f0;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .lp-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(15, 23, 42, 0.08);
    }

    .lp-icon {
        width: 48px; height: 48px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 16px;
    }

    .lp-icon.blue   { background: #dbeafe; color: #2563eb; }
    .lp-icon.purple  { background: #ede9fe; color: #7c3aed; }
    .lp-icon.green   { background: #dcfce7; color: #16a34a; }
    .lp-icon.orange  { background: #ffedd5; color: #ea580c; }
    .lp-icon.red     { background: #fee2e2; color: #dc2626; }
    .lp-icon.cyan    { background: #cffafe; color: #0891b2; }

    .lp-card h3 {
        font-size: 16px; font-weight: 700; color: #0f172a;
        margin-bottom: 8px;
    }

    .lp-card p {
        font-size: 14px; color: #64748b; line-height: 1.6;
    }

    /* ===== HOW IT WORKS ===== */
    .lp-how {
        padding: 96px 0;
        background: white;
    }

    .lp-steps {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 32px;
        text-align: center;
    }

    .lp-step-num {
        width: 48px; height: 48px;
        border-radius: 50%;
        background: linear-gradient(135deg, #2563eb, #0ea5e9);
        color: white;
        font-size: 20px; font-weight: 800;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 16px;
    }

    .lp-step h3 {
        font-size: 16px; font-weight: 700; color: #0f172a;
        margin-bottom: 8px;
    }

    .lp-step p {
        font-size: 14px; color: #64748b; line-height: 1.6;
    }

    /* ===== CTA ===== */
    .lp-cta {
        padding: 80px 0;
        background: linear-gradient(135deg, #1e3a8a, #2563eb);
        text-align: center;
        color: white;
    }

    .lp-cta h2 {
        font-size: 32px; font-weight: 800;
        margin-bottom: 12px;
    }

    .lp-cta p {
        font-size: 16px; opacity: 0.85;
        margin-bottom: 28px;
    }

    /* ===== FOOTER ===== */
    .lp-footer {
        padding: 28px 0;
        background: #0f172a;
        text-align: center;
    }

    .lp-footer p {
        font-size: 13px; color: #64748b;
    }

    /* ===== RESPONSIVE ===== */
    @@media (max-width: 768px) {
        .lp-burger { display: flex; align-items: center; }

        .lp-links {
            display: none;
            position: absolute;
            top: 60px; left: 0; right: 0;
            flex-direction: column;
            background: white;
            padding: 16px 20px;
            gap: 4px;
            border-bottom: 1px solid #e2e8f0;
            box-shadow: 0 8px 24px rgba(0,0,0,0.08);
        }

        .lp-links.open { display: flex; }

        .lp-links a {
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 15px;
        }

        .lp-links a:hover { background: #f8fafc; }

        .lp-cta-link {
            text-align: center; display: block !important;
            margin-top: 4px;
        }

        .lp-hero { padding: 110px 0 72px; }

        .lp-hero h1 { font-size: 32px; }

        .lp-hero p { font-size: 16px; }

        .lp-grid {
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        .lp-steps {
            grid-template-columns: 1fr;
            gap: 28px;
        }

        .lp-features, .lp-how { padding: 64px 0; }

        .lp-features h2, .lp-how h2 {
            font-size: 26px;
            margin-bottom: 32px;
        }

        .lp-cta h2 { font-size: 26px; }
        .lp-cta { padding: 64px 0; }
    }

    @@media (max-width: 480px) {
        .lp-hero h1 { font-size: 26px; }
        .lp-hero p { font-size: 15px; }
        .lp-pill { font-size: 12px; margin-bottom: 20px; }

        .lp-grid { grid-template-columns: 1fr; }

        .lp-card { padding: 22px 20px; }

        .lp-hero-btns { flex-direction: column; }
        .lp-btn { width: 100%; }

        .lp-features h2, .lp-how h2 { font-size: 22px; }
        .lp-cta h2 { font-size: 22px; }
    }
</style>

@code {
    private bool menuOpen = false;
}
