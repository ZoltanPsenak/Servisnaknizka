@page "/login"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Prihlásenie</PageTitle>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <h1>Elektronická servisná knižka</h1>
            <p>Prihlásenie do systému</p>
        </div>

        <EditForm Model="loginModel" OnValidSubmit="HandleLogin" class="login-form">
            <DataAnnotationsValidator />
            
            <div class="form-group">
                <label for="email">E-mailová adresa</label>
                <InputText id="email" @bind-Value="loginModel.Email" class="form-control" placeholder="váš@email.sk" />
                <ValidationMessage For="@(() => loginModel.Email)" />
            </div>

            <div class="form-group">
                <label for="password">Heslo</label>
                <InputText id="password" @bind-Value="loginModel.Password" type="password" class="form-control" placeholder="Zadajte heslo" />
                <ValidationMessage For="@(() => loginModel.Password)" />
            </div>

            <div class="form-check">
                <InputCheckbox id="remember" @bind-Value="loginModel.RememberMe" class="form-check-input" />
                <label for="remember" class="form-check-label">
                    Zapamätať si ma
                </label>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @errorMessage
                </div>
            }

            <button type="submit" class="btn btn-primary btn-login" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                }
                Prihlásiť sa
            </button>

            <div class="login-links">
                <a href="/register" class="text-decoration-none">Nemáte účet? Registrujte sa</a>
                <a href="/forgot-password" class="text-decoration-none">Zabudnuté heslo?</a>
            </div>

            <!-- Zobrazenie testovacích údajov -->
            <div class="mt-4 p-3 bg-light rounded">
                <small class="text-muted">
                    <strong>Testovacie účty:</strong><br/>
                    <strong>Admin:</strong> admin@servis.sk / Admin123!<br/>
                    <strong>Majiteľ:</strong> majitel@vozidlo.sk / Owner123!<br/>
                    <strong>Servis:</strong> servis@autoservis.sk / Service123!
                </small>
            </div>
        </EditForm>

        <div class="login-footer">
            <p class="text-muted">
                Bezpečný systém pre správu servisných záznamov vozidiel
            </p>
        </div>
    </div>
</div>

@code {
    private LoginModel loginModel = new();
    private string errorMessage = string.Empty;
    private bool isLoading = false;

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            // Simulate authentication delay
            await Task.Delay(1000);

            // ? OPRAVENÉ HESLÁ - teraz zodpovedajú databáze
            if (loginModel.Email == "admin@servis.sk" && loginModel.Password == "Admin123!")
            {
                await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "isAuthenticated", "true");
                await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "userEmail", loginModel.Email);
                await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "userRole", "admin");
                
                Navigation.NavigateTo("/dashboard", forceLoad: true);
            }
            else if (loginModel.Email == "majitel@vozidlo.sk" && loginModel.Password == "Owner123!")
            {
                await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "isAuthenticated", "true");
                await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "userEmail", loginModel.Email);
                await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "userRole", "owner");
                
                Navigation.NavigateTo("/dashboard", forceLoad: true);
            }
            else if (loginModel.Email == "servis@autoservis.sk" && loginModel.Password == "Service123!")
            {
                await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "isAuthenticated", "true");
                await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "userEmail", loginModel.Email);
                await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "userRole", "service");
                
                Navigation.NavigateTo("/dashboard", forceLoad: true);
            }
            else
            {
                errorMessage = "Nesprávne prihlasovacie údaje. Skúste prosím znova.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Chyba pri prihlasovaní. Skúste to prosím znova.";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    public class LoginModel
    {
        [Required(ErrorMessage = "E-mailová adresa je povinná")]
        [EmailAddress(ErrorMessage = "Nesprávny formát e-mailovej adresy")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Heslo je povinné")]
        [MinLength(6, ErrorMessage = "Heslo musí mať aspoň 6 znakov")]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; } = false;
    }
}