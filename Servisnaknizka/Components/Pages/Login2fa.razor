@page "/login-2fa"
@layout EmptyLayout
@rendermode InteractiveServer
@inject NavigationManager Navigation

<PageTitle>Overenie 2FA - Servisná knižka</PageTitle>

<div class="lg">
    <div class="lg-bg">
        <div class="lg-orb lg-orb-1"></div>
        <div class="lg-orb lg-orb-2"></div>
    </div>

    <div class="lg-center">
        <div class="lg-card">
            <a href="/" class="lg-logo">Servisná Knižka</a>
            <div class="lg-lock-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0110 0v4"/>
                    <circle cx="12" cy="16" r="1"/>
                </svg>
            </div>
            <h1>Dvojfaktorové overenie</h1>
            <p class="lg-sub">Zadajte 6-miestny kód z vašej autentifikačnej aplikácie</p>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="lg-msg lg-msg-err">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    @errorMessage
                </div>
            }

            <form method="post" action="/api/auth/login-2fa" class="lg-form" data-enhance="false">
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                <input type="hidden" name="rememberMe" value="@rememberMe" />

                <div class="lg-field">
                    <label for="code">Overovací kód</label>
                    <div class="lg-input-wrap">
                        <svg class="lg-input-ic" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                        <input type="text" id="code" name="code" placeholder="000 000" required
                               maxlength="7" autocomplete="one-time-code" inputmode="numeric"
                               style="text-align:center;letter-spacing:6px;font-size:22px;font-weight:700;" />
                    </div>
                </div>

                <button type="submit" class="lg-btn">Overiť</button>
            </form>

            <div class="lg-footer">
                <a href="/login">Späť na prihlásenie</a>
            </div>
        </div>
    </div>
</div>

<style>
    *{margin:0;padding:0;box-sizing:border-box}
    :root{--p:#2563eb;--pd:#1d4ed8;--s:#0ea5e9;--d:#0f172a;--g:#64748b;--l:#f1f5f9;--w:#fff;--r:14px}

    .lg{min-height:100vh;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:linear-gradient(145deg,#1e3a8a 0%,#2563eb 50%,#0ea5e9 100%);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}

    .lg-bg{position:absolute;inset:0;pointer-events:none}
    .lg-orb{position:absolute;border-radius:50%;filter:blur(100px);opacity:.2}
    .lg-orb-1{width:500px;height:500px;background:#06b6d4;top:-200px;right:-100px;animation:orb 20s ease-in-out infinite}
    .lg-orb-2{width:400px;height:400px;background:#3b82f6;bottom:-150px;left:-80px;animation:orb 24s ease-in-out infinite reverse}
    @@keyframes orb{0%,100%{transform:translate(0,0)}50%{transform:translate(30px,-30px)}}

    .lg-center{position:relative;z-index:1;width:100%;max-width:420px;padding:24px}

    .lg-card{background:var(--w);border-radius:24px;padding:40px 36px;box-shadow:0 30px 80px rgba(0,0,0,.2);animation:fadeIn .5s ease}
    @@keyframes fadeIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

    .lg-logo{display:block;text-align:center;font-size:15px;font-weight:800;color:var(--p);text-decoration:none;letter-spacing:-.02em;margin-bottom:20px}

    .lg-lock-icon{text-align:center;margin-bottom:16px}

    .lg-card h1{font-size:22px;font-weight:900;color:var(--d);text-align:center;letter-spacing:-.02em;margin-bottom:6px}
    .lg-sub{text-align:center;font-size:14px;color:var(--g);margin-bottom:28px}

    .lg-msg{display:flex;align-items:center;gap:10px;padding:12px 14px;border-radius:10px;font-size:13px;font-weight:500;margin-bottom:20px}
    .lg-msg-err{background:#fee2e2;color:#991b1b;border:1px solid #fecaca}
    .lg-msg svg{flex-shrink:0}

    .lg-form{display:flex;flex-direction:column;gap:18px}

    .lg-field{display:flex;flex-direction:column;gap:6px}
    .lg-field label{font-size:13px;font-weight:600;color:var(--d)}

    .lg-input-wrap{position:relative;display:flex;align-items:center}
    .lg-input-ic{position:absolute;left:14px;color:#94a3b8;pointer-events:none}
    .lg-input-wrap input{width:100%;padding:13px 14px 13px 44px;border:1.5px solid #e2e8f0;border-radius:10px;font-size:14px;font-family:inherit;background:var(--l);transition:all .2s}
    .lg-input-wrap input:focus{outline:none;border-color:var(--p);background:var(--w);box-shadow:0 0 0 3px rgba(37,99,235,.1)}
    .lg-input-wrap input::placeholder{color:#94a3b8}

    .lg-btn{width:100%;padding:14px;background:linear-gradient(135deg,var(--p),var(--s));color:var(--w);border:none;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer;transition:all .25s;box-shadow:0 8px 24px rgba(37,99,235,.3);font-family:inherit;margin-top:4px}
    .lg-btn:hover{transform:translateY(-2px);box-shadow:0 12px 32px rgba(37,99,235,.4)}
    .lg-btn:active{transform:translateY(0)}

    .lg-footer{text-align:center;margin-top:24px;font-size:13px;color:var(--g)}
    .lg-footer a{color:var(--p);font-weight:600;text-decoration:none}
    .lg-footer a:hover{text-decoration:underline}

    @@media(max-width:480px){
        .lg-center{padding:16px}
        .lg-card{padding:28px 22px;border-radius:20px}
        .lg-card h1{font-size:20px}
    }
</style>

@code {
    private string errorMessage = string.Empty;
    private string returnUrl = "/dashboard";
    private string rememberMe = "false";

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        
        var error = query["error"];
        if (!string.IsNullOrEmpty(error))
        {
            errorMessage = error switch
            {
                "invalid_code" => "Nesprávny overovací kód. Skúste to znova.",
                _ => "Chyba pri overení."
            };
        }

        var ret = query["returnUrl"];
        if (!string.IsNullOrEmpty(ret))
        {
            returnUrl = ret;
        }

        var rm = query["rememberMe"];
        if (!string.IsNullOrEmpty(rm))
        {
            rememberMe = rm;
        }
    }
}
