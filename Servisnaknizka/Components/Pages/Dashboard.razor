</style>

@code {
    // State
    private bool isInitialized = false;
    private bool isAuthenticated = false;
    private bool isLoading = false;
    private bool showNewRecordForm = false;
    private string formMessage = string.Empty;
    private bool formSuccess = false;

    // User info
    private string userEmail = string.Empty;
    private string userRole = string.Empty;
    private int currentUserId = 0;

    // Data
    private List<Vehicle>? vehicles;
    private List<ServiceRecord>? serviceRecords;
    private Vehicle? selectedVehicle;
    private int selectedVehicleId = 0;

    // Admin data
    private List<User>? allUsers;
    private List<Vehicle>? allVehicles;
    private List<ServiceRecord>? recentRecords;

    // Form model
    private ServiceRecord newServiceRecord = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CheckAuthenticationAndLoadData();
            isInitialized = true;
            StateHasChanged();
        }
    }

    private async Task CheckAuthenticationAndLoadData()
    {
        try
        {
            var authResult = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "isAuthenticated");
            isAuthenticated = authResult == "true";

            if (!isAuthenticated)
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }

            userEmail = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "userEmail") ?? "";
            userRole = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "userRole") ?? "";

            // Get user from database
            var user = await DbContext.Users.FirstOrDefaultAsync(u => u.Email == userEmail);
            if (user != null)
            {
                currentUserId = user.Id;
                await LoadDataFromDatabase();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            Navigation.NavigateTo("/login", forceLoad: true);
        }
    }

    private async Task LoadDataFromDatabase()
    {
        try
        {
            if (userRole == "owner")
            {
                vehicles = await DbContext.Vehicles
                    .Where(v => v.OwnerId == currentUserId && v.IsActive)
                    .Include(v => v.ServiceRecords)
                    .ToListAsync();

                if (vehicles.Any())
                {
                    selectedVehicleId = vehicles.First().Id;
                    await SelectVehicle(selectedVehicleId);
                }
            }
            else if (userRole == "service")
            {
                vehicles = await DbContext.Vehicles
                    .Where(v => v.IsActive && v.ServicePermissions.Any(p => p.ServiceId == currentUserId && p.IsActive))
                    .Include(v => v.Owner)
                    .Include(v => v.ServiceRecords)
                    .ToListAsync();
            }
            else if (userRole == "admin")
            {
                allUsers = await DbContext.Users
                    .Include(u => u.OwnedVehicles)
                    .Include(u => u.CreatedServiceRecords)
                    .ToListAsync();

                allVehicles = await DbContext.Vehicles
                    .Include(v => v.Owner)
                    .Include(v => v.ServiceRecords)
                    .ToListAsync();

                recentRecords = await DbContext.ServiceRecords
                    .Include(r => r.Vehicle)
                    .Include(r => r.CreatedBy)
                    .OrderByDescending(r => r.ServiceDate)
                    .Take(10)
                    .ToListAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Database error: {ex.Message}");
        }
    }

    private async Task SelectVehicle(int vehicleId)
    {
        selectedVehicleId = vehicleId;
        selectedVehicle = vehicles?.FirstOrDefault(v => v.Id == vehicleId);
        
        if (selectedVehicle != null)
        {
            serviceRecords = await DbContext.ServiceRecords
                .Where(r => r.VehicleId == vehicleId)
                .Include(r => r.CreatedBy)
                .ToListAsync();
        }
        
        ClearForm();
    }

    private async Task SaveServiceRecord()
    {
        if (selectedVehicle == null) return;

        isLoading = true;
        formMessage = string.Empty;
        StateHasChanged();

        try
        {
            newServiceRecord.VehicleId = selectedVehicle.Id;
            newServiceRecord.CreatedById = currentUserId;
            newServiceRecord.CreatedAt = DateTime.UtcNow;

            DbContext.ServiceRecords.Add(newServiceRecord);
            await DbContext.SaveChangesAsync();

            formMessage = "Servisný záznam bol úspešne uložený!";
            formSuccess = true;

            await Task.Delay(1500);
            await LoadDataFromDatabase();
            await SelectVehicle(selectedVehicleId);
            
            showNewRecordForm = false;
        }
        catch (Exception ex)
        {
            formMessage = $"Chyba pri ukladaní: {ex.Message}";
            formSuccess = false;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void ClearForm()
    {
        newServiceRecord = new ServiceRecord
        {
            ServiceDate = DateTime.Today
        };
        formMessage = string.Empty;
        formSuccess = false;
        showNewRecordForm = false;
    }

    private async Task ShowAddVehicleModal()
    {
        await JSRuntime.InvokeVoidAsync("alert", "Funkcia pridania vozidla bude dostupná v nasledujúcej verzii.");
    }

    private async Task Logout()
    {
        await JSRuntime.InvokeVoidAsync("sessionStorage.clear");
        Navigation.NavigateTo("/", forceLoad: true);
    }

    // Helper methods
    private string GetUserInitials()
    {
        var parts = userEmail.Split('@')[0].Split('.');
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return userEmail.Substring(0, Math.Min(2, userEmail.Length)).ToUpper();
    }

    private string GetUserName()
    {
        var parts = userEmail.Split('@')[0].Split('.');
        if (parts.Length >= 2)
            return $"{char.ToUpper(parts[0][0])}{parts[0].Substring(1)} {char.ToUpper(parts[1][0])}{parts[1].Substring(1)}";
        return userEmail.Split('@')[0];
    }

    private string GetRoleDisplayName() => userRole switch
    {
        "owner" => "Majiteľ vozidla",
        "service" => "Autoservis",
        "admin" => "Administrátor",
        _ => "Používateľ"
    };

    private string GetVehicleServiceStatus(Vehicle vehicle)
    {
        var lastService = vehicle.ServiceRecords.OrderByDescending(r => r.ServiceDate).FirstOrDefault();
        if (lastService == null) return "Bez záznamu";
        
        var daysSince = (DateTime.Now - lastService.ServiceDate).Days;
        if (daysSince < 90) return "Aktuálny";
        if (daysSince < 180) return "Kontrola";
        return "Servis potrebný";
    }

    private string GetStatusClass(Vehicle vehicle)
    {
        var lastService = vehicle.ServiceRecords.OrderByDescending(r => r.ServiceDate).FirstOrDefault();
        if (lastService == null) return "warning";
        
        var daysSince = (DateTime.Now - lastService.ServiceDate).Days;
        if (daysSince < 90) return "success";
        if (daysSince < 180) return "warning";
        return "danger";
    }

    private int GetRecentServices()
    {
        if (serviceRecords == null) return 0;
        var lastMonth = DateTime.Now.AddMonths(-1);
        return serviceRecords.Count(r => r.ServiceDate >= lastMonth);
    }

    private string GetTotalCost()
    {
        if (serviceRecords == null) return "0";
        var total = serviceRecords.Where(r => r.Cost.HasValue).Sum(r => r.Cost.Value);
        return total.ToString("N0");
    }

    private int GetUniqueCustomers()
    {
        if (vehicles == null) return 0;
        return vehicles.Select(v => v.OwnerId).Distinct().Count();
    }

    private int GetTotalUsers() => allUsers?.Count ?? 0;
    private int GetTotalVehicles() => allVehicles?.Count ?? 0;
    private int GetTotalRecords() => allVehicles?.Sum(v => v.ServiceRecords.Count) ?? 0;
    private int GetTotalServices() => allUsers?.Count(u => u.Role == UserRole.Service) ?? 0;

    private string GetInitials(string firstName, string lastName)
    {
        return $"{firstName[0]}{lastName[0]}".ToUpper();
    }

