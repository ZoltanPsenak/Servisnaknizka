    private async Task AdminSaveUser()
    {
        editUserMessage = string.Empty;

        if (userRole != "admin")
        {
            editUserMessage = "Nemáte oprávnenie na túto akciu.";
            editUserSuccess = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(editUserFirstName) || string.IsNullOrWhiteSpace(editUserLastName) ||
            string.IsNullOrWhiteSpace(editUserEmail))
        {
            editUserMessage = "Vyplňte všetky polia.";
            editUserSuccess = false;
            return;
        }

        isLoading = true;
        StateHasChanged();

        try
        {
            var user = await DbContext.Users.FindAsync(editUserId);
            if (user == null)
            {
                editUserMessage = "Používateľ nebol nájdený.";
                editUserSuccess = false;
                isLoading = false;
                return;
            }

            user.FirstName = editUserFirstName;
            user.LastName = editUserLastName;

            // Zmena emailu
            if (user.Email != editUserEmail)
            {
                user.Email = editUserEmail;
                user.NormalizedEmail = editUserEmail.ToUpper();
                user.UserName = editUserEmail;
                user.NormalizedUserName = editUserEmail.ToUpper();
            }

            // Zmena roly
            var newRole = editUserRole switch
            {
                "Service" => UserRole.Service,
                "Admin" => UserRole.Admin,
                _ => UserRole.Owner
            };

            if (user.Role != newRole)
            {
                // Odstrániť starú rolu
                var oldRoleName = user.Role.ToString();
                var oldRoles = await UserManager.GetRolesAsync(user);
                if (oldRoles.Any())
                {
                    await UserManager.RemoveFromRolesAsync(user, oldRoles);
                }
                var oldClaims = await UserManager.GetClaimsAsync(user);
                var roleClaims = oldClaims.Where(c => c.Type == ClaimTypes.Role).ToList();
                foreach (var claim in roleClaims)
                {
                    await UserManager.RemoveClaimAsync(user, claim);
                }

                user.Role = newRole;
                await UserManager.AddToRoleAsync(user, editUserRole);
                await UserManager.AddClaimAsync(user, new Claim(ClaimTypes.Role, editUserRole));
            }

            await DbContext.SaveChangesAsync();

            editUserMessage = "Používateľ bol úspešne aktualizovaný!";
            editUserSuccess = true;
            showEditUserModal = false;

            await LoadDataFromDatabase();
        }
        catch (Exception ex)
        {
            editUserMessage = $"Chyba: {ex.Message}";
            editUserSuccess = false;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

