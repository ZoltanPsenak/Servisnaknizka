    // ========== 2FA METHODS ==========

    private async Task Start2faSetup()
    {
        try
        {
            isLoading = true;
            twoFaMessage = string.Empty;
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var currentUser = await UserManager.GetUserAsync(authState.User);
            if (currentUser == null) return;

            await UserManager.ResetAuthenticatorKeyAsync(currentUser);
            var key = await UserManager.GetAuthenticatorKeyAsync(currentUser);
            if (string.IsNullOrEmpty(key)) return;

            twoFaSharedKey = FormatKey(key);
            var email = await UserManager.GetEmailAsync(currentUser);
            var otpauthUri = $"otpauth://totp/ServisnaKnizka:{Uri.EscapeDataString(email ?? "")}" +
                             $"?secret={key}&issuer=ServisnaKnizka&digits=6";

            // Generate QR code using QRCoder
            using var qrGenerator = new QRCoder.QRCodeGenerator();
            using var qrCodeData = qrGenerator.CreateQrCode(otpauthUri, QRCoder.QRCodeGenerator.ECCLevel.Q);
            using var qrCode = new QRCoder.PngByteQRCode(qrCodeData);
            var qrCodeBytes = qrCode.GetGraphic(5);
            twoFaQrCodeDataUri = $"data:image/png;base64,{Convert.ToBase64String(qrCodeBytes)}";

            show2faSetup = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"2FA setup error: {ex.Message}");
            twoFaMessage = "Chyba pri nastavovaní 2FA.";
            twoFaSuccess = false;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task Verify2faSetup()
    {
        try
        {
            isLoading = true;
            twoFaMessage = string.Empty;
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var currentUser = await UserManager.GetUserAsync(authState.User);
            if (currentUser == null) return;

            var code = verifyCode.Replace(" ", string.Empty).Replace("-", string.Empty);
            var isValid = await UserManager.VerifyTwoFactorTokenAsync(
                currentUser,
                UserManager.Options.Tokens.AuthenticatorTokenProvider,
                code);

            if (isValid)
            {
                await UserManager.SetTwoFactorEnabledAsync(currentUser, true);
                is2faEnabled = true;
                show2faSetup = false;
                twoFaMessage = "2FA bolo úspešne aktivované!";
                twoFaSuccess = true;
                verifyCode = string.Empty;
                twoFaQrCodeDataUri = string.Empty;
                twoFaSharedKey = string.Empty;
            }
            else
            {
                twoFaMessage = "Nesprávny overovací kód. Skúste to znova.";
                twoFaSuccess = false;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"2FA verify error: {ex.Message}");
            twoFaMessage = "Chyba pri overovaní kódu.";
            twoFaSuccess = false;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task Disable2fa()
    {
        try
        {
            isLoading = true;
            twoFaMessage = string.Empty;
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var currentUser = await UserManager.GetUserAsync(authState.User);
            if (currentUser == null) return;

            var code = disableCode.Replace(" ", string.Empty).Replace("-", string.Empty);
            var isValid = await UserManager.VerifyTwoFactorTokenAsync(
                currentUser,
                UserManager.Options.Tokens.AuthenticatorTokenProvider,
                code);

            if (isValid)
            {
                await UserManager.SetTwoFactorEnabledAsync(currentUser, false);
                await UserManager.ResetAuthenticatorKeyAsync(currentUser);
                is2faEnabled = false;
                twoFaMessage = "2FA bolo vypnuté.";
                twoFaSuccess = true;
                disableCode = string.Empty;
            }
            else
            {
                twoFaMessage = "Nesprávny overovací kód.";
                twoFaSuccess = false;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"2FA disable error: {ex.Message}");
            twoFaMessage = "Chyba pri vypínaní 2FA.";
            twoFaSuccess = false;
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string FormatKey(string key)
    {
        var result = new System.Text.StringBuilder();
        int count = 0;
        foreach (var c in key)
        {
            result.Append(c);
            count++;
            if (count % 4 == 0 && count < key.Length) result.Append(' ');
        }
        return result.ToString();
    }

