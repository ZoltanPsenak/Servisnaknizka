@code {
    // State
    private bool isInitialized = false;
    private bool isAuthenticated = false;
    private bool isLoading = false;
    private bool showNewRecordForm = false;
    private string formMessage = string.Empty;
    private bool formSuccess = false;

    // User info
    private string userEmail = string.Empty;
    private string userRole = string.Empty;
    private int currentUserId = 0;

    // Data from database
    private List<Vehicle>? vehicles;
    private List<ServiceRecord>? serviceRecords;
    private Vehicle? selectedVehicle;
    private int selectedVehicleId = 0;

    // Form model
    private ServiceRecord newServiceRecord = new();

    protected override void OnInitialized()
    {
        newServiceRecord = new ServiceRecord
        {
            ServiceDate = DateTime.Today,
            ServiceType = ""
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CheckAuthenticationAndLoadData();
            StateHasChanged();
        }
    }

    private async Task CheckAuthenticationAndLoadData()
    {
        try
        {
            var authStatus = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "isAuthenticated");
            
            if (string.IsNullOrEmpty(authStatus) || authStatus != "true")
            {
                isAuthenticated = false;
                isInitialized = true;
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }

            userEmail = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "userEmail") ?? "";
            userRole = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "userRole") ?? "owner";

            isAuthenticated = true;
            await LoadDataFromDatabase();
            isInitialized = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Auth error: {ex.Message}");
            isAuthenticated = false;
            isInitialized = true;
            Navigation.NavigateTo("/login", forceLoad: true);
        }
    }

    private async Task LoadDataFromDatabase()
    {
        try
        {
            var user = await DbContext.Users.FirstOrDefaultAsync(u => u.Email == userEmail);

            if (user != null)
            {
                currentUserId = user.Id;

                if (user.Role == UserRole.Owner)
                {
                    vehicles = await DbContext.Vehicles
                        .Where(v => v.OwnerId == user.Id && v.IsActive)
                        .Include(v => v.ServiceRecords)
                        .OrderBy(v => v.Brand)
                        .ThenBy(v => v.Model)
                        .ToListAsync();
                }
                else if (user.Role == UserRole.Service)
                {
                    vehicles = await DbContext.Vehicles
                        .Where(v => v.IsActive && v.ServicePermissions.Any(p => p.ServiceId == user.Id && p.IsActive))
                        .Include(v => v.ServiceRecords)
                        .Include(v => v.Owner)
                        .OrderBy(v => v.Brand)
                        .ThenBy(v => v.Model)
                        .ToListAsync();
                }
                else if (user.Role == UserRole.Admin)
                {
                    vehicles = await DbContext.Vehicles
                        .Where(v => v.IsActive)
                        .Include(v => v.ServiceRecords)
                        .Include(v => v.Owner)
                        .OrderBy(v => v.Brand)
                        .ThenBy(v => v.Model)
                        .ToListAsync();
                }

                if (vehicles != null && vehicles.Any())
                {
                    await SelectVehicle(vehicles.First().Id);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Database error: {ex.Message}");
            vehicles = new List<Vehicle>();
        }
    }

    private async Task SelectVehicle(int vehicleId)
    {
        selectedVehicleId = vehicleId;
        selectedVehicle = vehicles?.FirstOrDefault(v => v.Id == vehicleId);

        if (selectedVehicle != null)
        {
            serviceRecords = await DbContext.ServiceRecords
                .Where(sr => sr.VehicleId == vehicleId)
                .Include(sr => sr.CreatedBy)
                .OrderByDescending(sr => sr.ServiceDate)
                .ToListAsync();

            newServiceRecord.VehicleId = vehicleId;
        }
    }

    private string GetRoleDisplayName()
    {
        return userRole switch
        {
            "admin" => "Administrátor",
            "owner" => "Majiteľ",
            "service" => "Servis",
            _ => "Používateľ"
        };
    }

    private string GetVehicleServiceStatus(Vehicle vehicle)
    {
        if (vehicle.ServiceRecords == null || !vehicle.ServiceRecords.Any())
            return "Žiadny servis";

        var lastService = vehicle.ServiceRecords.OrderByDescending(r => r.ServiceDate).FirstOrDefault();
        if (lastService == null) return "Žiadny servis";

        var daysSinceService = (DateTime.Today - lastService.ServiceDate).Days;
        
        if (daysSinceService < 180)
            return "Aktuálny";
        else if (daysSinceService < 365)
            return "Blíži sa";
        else
            return "Potrebný";
    }

    private string GetStatusClass(Vehicle vehicle)
    {
        if (vehicle.ServiceRecords == null || !vehicle.ServiceRecords.Any())
            return "danger";

        var lastService = vehicle.ServiceRecords.OrderByDescending(r => r.ServiceDate).FirstOrDefault();
        if (lastService == null) return "danger";

        var daysSinceService = (DateTime.Today - lastService.ServiceDate).Days;
        
        if (daysSinceService < 180)
            return "success";
        else if (daysSinceService < 365)
            return "warning";
        else
            return "danger";
    }

    private async Task SaveServiceRecord()
    {
        if (selectedVehicle == null)
        {
            formMessage = "Vyberte vozidlo pre pridanie záznamu.";
            formSuccess = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(newServiceRecord.Description))
        {
            formMessage = "Popis úkonu je povinný.";
            formSuccess = false;
            return;
        }

        isLoading = true;
        formMessage = string.Empty;

        try
        {
            newServiceRecord.VehicleId = selectedVehicle.Id;
            newServiceRecord.CreatedById = currentUserId;
            newServiceRecord.CreatedAt = DateTime.UtcNow;

            DbContext.ServiceRecords.Add(newServiceRecord);
            await DbContext.SaveChangesAsync();

            formMessage = "Servisný záznam bol úspešne uložený!";
            formSuccess = true;

            await SelectVehicle(selectedVehicle.Id);
            ClearForm();

            _ = Task.Delay(3000).ContinueWith(_ =>
            {
                formMessage = string.Empty;
                InvokeAsync(StateHasChanged);
            });
        }
        catch (Exception ex)
        {
            formMessage = $"Chyba pri ukladaní: {ex.Message}";
            formSuccess = false;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ClearForm()
    {
        newServiceRecord = new ServiceRecord
        {
            ServiceDate = DateTime.Today,
            ServiceType = "",
            VehicleId = selectedVehicleId
        };
    }

    private async Task ShowAddVehicleModal()
    {
        await JSRuntime.InvokeVoidAsync("alert", "Funkcia pridávania vozidiel bude dostupná v ďalšej verzii.");
    }

    private async Task ExportAllRecords()
    {
        await JSRuntime.InvokeVoidAsync("alert", "Export do PDF bude dostupný v ďalšej verzii.");
    }

    private async Task Logout()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("sessionStorage.clear");
        }
        catch { }
        
        Navigation.NavigateTo("/", forceLoad: true);
    }
}