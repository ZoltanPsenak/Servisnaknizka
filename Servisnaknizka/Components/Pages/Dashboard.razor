    protected override async Task OnInitializedAsync()
    {
        await CheckAuthenticationAndLoadData();
    }

    private async Task CheckAuthenticationAndLoadData()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated != true)
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }

            var currentUser = await UserManager.GetUserAsync(user);
            if (currentUser == null)
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }

            currentUserId = currentUser.Id;
            userEmail = currentUser.Email ?? "";
            currentFirstName = currentUser.FirstName;
            currentLastName = currentUser.LastName;
            userRole = currentUser.Role.ToString().ToLower();
            isAuthenticated = true;
            is2faEnabled = await UserManager.GetTwoFactorEnabledAsync(currentUser);

            await LoadDataFromDatabase();
            await LoadNotifications();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Auth check error: {ex.Message}");
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }
        finally
        {
            isInitialized = true;
            StateHasChanged();
        }
    }

    private async Task LoadDataFromDatabase()
    {
        try
        {
            if (userRole == "admin")
            {
                allUsers = await DbContext.Users
                    .Include(u => u.OwnedVehicles)
                    .Include(u => u.CreatedServiceRecords)
                    .OrderByDescending(u => u.CreatedAt)
                    .ToListAsync();

                allVehicles = await DbContext.Vehicles
                    .Where(v => v.IsActive)
                    .Include(v => v.Owner)
                    .Include(v => v.ServiceRecords)
                    .OrderByDescending(v => v.CreatedAt)
                    .ToListAsync();

                recentRecords = await DbContext.ServiceRecords
                    .Include(sr => sr.Vehicle)
                    .Include(sr => sr.CreatedBy)
                    .OrderByDescending(sr => sr.ServiceDate)
                    .Take(10)
                    .ToListAsync();

                allPermissions = await DbContext.Permissions
                    .Include(p => p.Service)
                    .Include(p => p.Vehicle)
                    .Where(p => p.IsActive)
                    .OrderByDescending(p => p.GrantedAt)
                    .ToListAsync();

                allServicesData = await DbContext.Services
                    .Include(s => s.User)
                    .OrderByDescending(s => s.CreatedAt)
                    .ToListAsync();
            }
            else if (userRole == "owner")
            {
                vehicles = await DbContext.Vehicles
                    .Where(v => v.OwnerId == currentUserId && v.IsActive)
                    .Include(v => v.ServiceRecords)
                    .ThenInclude(sr => sr.CreatedBy)
                    .OrderBy(v => v.Brand)
                    .ThenBy(v => v.Model)
                    .ToListAsync();

                vehiclePermissions = await DbContext.Permissions
                    .Include(p => p.Service)
                    .Include(p => p.Vehicle)
                    .Where(p => p.Vehicle.OwnerId == currentUserId && p.IsActive)
                    .OrderByDescending(p => p.GrantedAt)
                    .ToListAsync();

                if (vehicles.Any())
                {
                    if (selectedVehicleId > 0)
                    {
                        selectedVehicle = vehicles.FirstOrDefault(v => v.Id == selectedVehicleId);
                    }
                    selectedVehicle ??= vehicles.First();
                    selectedVehicleId = selectedVehicle.Id;
                    serviceRecords = selectedVehicle.ServiceRecords
                        .OrderByDescending(sr => sr.ServiceDate)
                        .ToList();
                }
            }
            else if (userRole == "service")
            {
                // Načítať profil servisu
                currentServiceProfile = await DbContext.Services
                    .Include(s => s.User)
                    .FirstOrDefaultAsync(s => s.UserId == currentUserId);

                if (currentServiceProfile != null)
                {
                    svcFormCompanyName = currentServiceProfile.CompanyName;
                    svcFormICO = currentServiceProfile.ICO ?? string.Empty;
                    svcFormAddress = currentServiceProfile.Address ?? string.Empty;
                    svcFormCity = currentServiceProfile.City ?? string.Empty;
                    svcFormPostalCode = currentServiceProfile.PostalCode ?? string.Empty;
                    svcFormPhone = currentServiceProfile.Phone ?? string.Empty;
                    svcFormContactEmail = currentServiceProfile.ContactEmail ?? string.Empty;
                    svcFormDescription = currentServiceProfile.Description ?? string.Empty;
                }

                vehicles = await DbContext.Vehicles
                    .Where(v => v.IsActive && v.ServicePermissions.Any(p => p.ServiceId == currentUserId && p.IsActive))
                    .Include(v => v.Owner)
                    .Include(v => v.ServiceRecords)
                    .ThenInclude(sr => sr.CreatedBy)
                    .OrderBy(v => v.Brand)
                    .ThenBy(v => v.Model)
                    .ToListAsync();

                if (vehicles.Any())
                {
                    if (selectedVehicleId > 0)
                    {
                        selectedVehicle = vehicles.FirstOrDefault(v => v.Id == selectedVehicleId);
                    }
                    selectedVehicle ??= vehicles.First();
                    selectedVehicleId = selectedVehicle.Id;
                    serviceRecords = selectedVehicle.ServiceRecords
                        .OrderByDescending(sr => sr.ServiceDate)
                        .ToList();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
    }

    private async Task SelectVehicle(int vehicleId)
    {
        if (vehicles == null) return;

        selectedVehicle = vehicles.FirstOrDefault(v => v.Id == vehicleId);
        selectedVehicleId = vehicleId;

        if (selectedVehicle != null)
        {
            serviceRecords = selectedVehicle.ServiceRecords
                .OrderByDescending(sr => sr.ServiceDate)
                .ToList();
        }

        showNewRecordForm = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveServiceRecord()
    {
        if (selectedVehicle == null) return;

        isLoading = true;
        formMessage = string.Empty;
        StateHasChanged();

        try
        {
            newServiceRecord.VehicleId = selectedVehicle.Id;
            newServiceRecord.CreatedById = currentUserId;
            newServiceRecord.CreatedAt = DateTime.UtcNow;

            DbContext.ServiceRecords.Add(newServiceRecord);
            await DbContext.SaveChangesAsync();

            await LoadDataFromDatabase();
            await SelectVehicle(selectedVehicleId);

            formMessage = "Servisný záznam bol úspešne uložený!";
            formSuccess = true;
            ClearForm();
            showNewRecordForm = false;
        }
        catch (Exception ex)
        {
            formMessage = $"Chyba pri ukladaní: {ex.Message}";
            formSuccess = false;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

