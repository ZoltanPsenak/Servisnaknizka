@page "/dashboard"
@layout EmptyLayout
@rendermode InteractiveServer
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject ApplicationDbContext DbContext
@inject UserManager<User> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize]

<PageTitle>Dashboard - Servisná knižka</PageTitle>

<div class="cd-dashboard">
@if (!isInitialized)
{
    <div class="cd-loading">
        <div class="cd-loading-spinner"></div>
        <p>Načítavam...</p>
    </div>
}
else if (!isAuthenticated)
{
    <div class="cd-loading">
        <p>Presmerováva sa na prihlasovaciu stránku...</p>
    </div>
}
else
{
    <!-- NAVBAR -->
    <nav class="cd-navbar">
        <div class="cd-nav-inner">
            <div class="cd-brand">
                <div class="cd-brand-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                </div>
                <span>Servisná Knižka</span>
            </div>
            <div class="cd-nav-right">
                <div class="cd-user-pill">
                    <div class="cd-avatar">@GetUserInitials()</div>
                    <div class="cd-user-text">
                        <span class="cd-user-name">@GetUserName()</span>
                        <span class="cd-user-role">@GetRoleDisplayName()</span>
                    </div>
                </div>
                <button @onclick="() => show2faSettings = !show2faSettings" class="cd-btn-logout" title="Nastavenia 2FA">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
                    </svg>
                    <span>2FA</span>
                </button>
                <button @onclick="ToggleNotifications" class="cd-notif-btn" title="Pripomienky">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                    @if (unreadCount > 0)
                    {
                        <span class="cd-notif-badge">@(unreadCount > 9 ? "9+" : unreadCount.ToString())</span>
                    }
                </button>
                <button @onclick="Logout" class="cd-btn-logout">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    <span>Odhlásiť sa</span>
                </button>
            </div>
        </div>
    </nav>

    <!-- MAIN -->
    <!-- NOTIFICATION PANEL -->
    @if (showNotifPanel)
    {
        <div class="cd-notif-overlay" @onclick="() => showNotifPanel = false"></div>
        <div class="cd-notif-panel">
            <div class="cd-notif-header">
                <h3>Pripomienky</h3>
                <button @onclick="() => showNotifPanel = false" class="cd-modal-close">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="cd-notif-list">
                @if (notifications.Any())
                {
                    @foreach (var notif in notifications)
                    {
                        <div class="cd-notif-item @(notif.IsRead ? "" : "unread")" @onclick="() => MarkAsRead(notif.Id)">
                            <div class="cd-ni-top">
                                <div style="display:flex;align-items:center;">
                                    <span class="cd-ni-type @notif.Type"></span>
                                    <span class="cd-ni-title">@notif.Title</span>
                                </div>
                                <span class="cd-ni-time">@FormatNotifTime(notif.CreatedAt)</span>
                            </div>
                            <div class="cd-ni-msg">@notif.Message</div>
                        </div>
                    }
                }
                else
                {
                    <div class="cd-notif-empty">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                        <p>Žiadne pripomienky</p>
                    </div>
                }
            </div>
            @if (notifications.Any(n => !n.IsRead))
            {
                <div class="cd-notif-actions">
                    <button @onclick="MarkAllAsRead" class="cd-btn cd-btn-ghost" style="width:100%;font-size:13px;">Označiť všetko ako prečítané</button>
                </div>
            }
        </div>
    }

    <!-- REMINDER SETTINGS MODAL -->
    @if (showReminderModal)
    {
        <div class="cd-modal-overlay" @onclick="() => showReminderModal = false">
            <div class="cd-modal-reminder" @onclick:stopPropagation="true">
                <div class="cd-modal-header">
                    <h2>Pripomienky a termíny</h2>
                    <button @onclick="() => showReminderModal = false" class="cd-modal-close">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
                <div class="cd-modal-body" style="max-height:70vh;overflow-y:auto;">
                    <div class="cd-reminder-info">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0369a1" stroke-width="2" style="flex-shrink:0;margin-top:2px;"><path d="M7 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0"/><path d="M17 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0"/><path d="M5 17H3v-6l2-5h9l4 5h1a2 2 0 0 1 2 2v4h-2"/><path d="M9 17h6"/></svg>
                        <p><strong>@reminderVehicleName</strong><br/>Nastavte termíny a pripomienky pre toto vozidlo.</p>
                    </div>

                    <!-- SERVISNÝ INTERVAL -->
                    <div class="cd-reminder-section">
                        <h4 class="cd-reminder-section-title">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
                            Pravidelný servis
                        </h4>
                        <div class="cd-interval-options">
                            <button class="cd-interval-opt @(reminderInterval == 0 ? "active" : "")" @onclick="() => reminderInterval = 0">Vyp.</button>
                            <button class="cd-interval-opt @(reminderInterval == 3 ? "active" : "")" @onclick="() => reminderInterval = 3">3 mes.</button>
                            <button class="cd-interval-opt @(reminderInterval == 6 ? "active" : "")" @onclick="() => reminderInterval = 6">6 mes.</button>
                            <button class="cd-interval-opt @(reminderInterval == 12 ? "active" : "")" @onclick="() => reminderInterval = 12">12 mes.</button>
                            <button class="cd-interval-opt @(reminderInterval == 24 ? "active" : "")" @onclick="() => reminderInterval = 24">24 mes.</button>
                        </div>
                        <p class="cd-reminder-hint">
                            @if (reminderInterval == 0) { <span>Pripomienky pravidelného servisu sú vypnuté.</span> }
                            else { <span>Upozornenie 30 a 7 dní pred plánovaným servisom.</span> }
                        </p>
                    </div>

                    <!-- STK -->
                    <div class="cd-reminder-section">
                        <h4 class="cd-reminder-section-title">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            STK (Technická kontrola)
                        </h4>
                        <div class="cd-form-row" style="gap:12px;">
                            <div class="cd-field" style="flex:1;">
                                <label>Platnosť STK do</label>
                                <input type="date" @bind="reminderStkExpiry" class="cd-input" />
                            </div>
                            @if (reminderStkExpiry.HasValue)
                            {
                                <div style="display:flex;align-items:end;padding-bottom:2px;">
                                    <button @onclick="() => reminderStkExpiry = null" class="cd-btn-icon" title="Vymazať" style="color:#dc2626;">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                    </button>
                                </div>
                            }
                        </div>
                        <p class="cd-reminder-hint">@GetExpiryHint(reminderStkExpiry, "STK")</p>
                    </div>

                    <!-- EMISNÁ KONTROLA -->
                    <div class="cd-reminder-section">
                        <h4 class="cd-reminder-section-title">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2"><path d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            Emisná kontrola
                        </h4>
                        <div class="cd-form-row" style="gap:12px;">
                            <div class="cd-field" style="flex:1;">
                                <label>Platnosť EK do</label>
                                <input type="date" @bind="reminderEmissionExpiry" class="cd-input" />
                            </div>
                            @if (reminderEmissionExpiry.HasValue)
                            {
                                <div style="display:flex;align-items:end;padding-bottom:2px;">
                                    <button @onclick="() => reminderEmissionExpiry = null" class="cd-btn-icon" title="Vymazať" style="color:#dc2626;">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                    </button>
                                </div>
                            }
                        </div>
                        <p class="cd-reminder-hint">@GetExpiryHint(reminderEmissionExpiry, "emisnej kontroly")</p>
                    </div>

                    <!-- POISTENIE -->
                    <div class="cd-reminder-section">
                        <h4 class="cd-reminder-section-title">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                            PZP / Havarijné poistenie
                        </h4>
                        <div class="cd-form-row" style="gap:12px;">
                            <div class="cd-field" style="flex:1;">
                                <label>Platnosť poistenia do</label>
                                <input type="date" @bind="reminderInsuranceExpiry" class="cd-input" />
                            </div>
                            @if (reminderInsuranceExpiry.HasValue)
                            {
                                <div style="display:flex;align-items:end;padding-bottom:2px;">
                                    <button @onclick="() => reminderInsuranceExpiry = null" class="cd-btn-icon" title="Vymazať" style="color:#dc2626;">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                    </button>
                                </div>
                            }
                        </div>
                        <p class="cd-reminder-hint">@GetExpiryHint(reminderInsuranceExpiry, "poistenia")</p>
                    </div>

                    @if (!string.IsNullOrEmpty(reminderMessage))
                    {
                        <div class="cd-alert @(reminderSuccess ? "cd-alert-ok" : "cd-alert-err")" style="margin-top:12px;">
                            @reminderMessage
                        </div>
                    }

                    <div class="cd-form-actions" style="margin-top:20px;">
                        <button @onclick="() => showReminderModal = false" class="cd-btn cd-btn-ghost">Zrušiť</button>
                        <button @onclick="SaveReminderSettings" class="cd-btn cd-btn-primary" disabled="@isLoading">Uložiť všetko</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- 2FA SETTINGS MODAL -->
    @if (show2faSettings)
    {
        <div class="cd-modal-overlay" @onclick="() => show2faSettings = false">
            <div class="cd-modal-2fa" @onclick:stopPropagation="true">
                <div class="cd-modal-header">
                    <h2>Dvojfaktorové overenie (2FA)</h2>
                    <button @onclick="() => show2faSettings = false" class="cd-modal-close">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
                <div class="cd-modal-body">
                    @if (is2faEnabled)
                    {
                        <div class="cd-2fa-status cd-2fa-active">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 12 15 16 9" stroke="#16a34a"/></svg>
                            <div>
                                <strong>2FA je aktivované</strong>
                                <p>Váš účet je chránený dvojfaktorovým overením.</p>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(twoFaMessage))
                        {
                            <div class="cd-alert @(twoFaSuccess ? "cd-alert-ok" : "cd-alert-err")" style="margin-top:16px;">
                                @twoFaMessage
                            </div>
                        }

                        <div class="cd-2fa-disable">
                            <p style="color:#64748b;font-size:13px;margin-bottom:12px;">Ak chcete vypnúť 2FA, zadajte overovací kód z aplikácie:</p>
                            <div style="display:flex;gap:12px;align-items:end;">
                                <div class="cd-field" style="flex:1;">
                                    <label>Overovací kód</label>
                                    <input type="text" @bind="disableCode" class="cd-input" maxlength="7" placeholder="000 000" style="text-align:center;letter-spacing:4px;font-weight:700;" />
                                </div>
                                <button @onclick="Disable2fa" class="cd-btn cd-btn-danger" disabled="@isLoading" style="height:44px;">Vypnúť 2FA</button>
                            </div>
                        </div>
                    }
                    else if (show2faSetup)
                    {
                        <div class="cd-2fa-setup">
                            <div class="cd-2fa-steps">
                                <div class="cd-2fa-step">
                                    <div class="cd-2fa-step-num">1</div>
                                    <div>
                                        <strong>Nainštalujte autentifikačnú aplikáciu</strong>
                                        <p>Stiahnite si Google Authenticator, Microsoft Authenticator alebo inú TOTP aplikáciu.</p>
                                    </div>
                                </div>
                                <div class="cd-2fa-step">
                                    <div class="cd-2fa-step-num">2</div>
                                    <div>
                                        <strong>Naskenujte QR kód</strong>
                                        <p>Otvorte aplikáciu a naskenujte tento QR kód:</p>
                                    </div>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(twoFaQrCodeDataUri))
                            {
                                <div class="cd-2fa-qr">
                                    <img src="@twoFaQrCodeDataUri" alt="QR kód pre 2FA" width="200" height="200" />
                                </div>
                            }

                            <div class="cd-2fa-manual">
                                <p style="font-size:12px;color:#64748b;margin-bottom:6px;">Alebo zadajte kód manuálne:</p>
                                <code class="cd-2fa-key">@twoFaSharedKey</code>
                            </div>

                            <div class="cd-2fa-step" style="margin-top:20px;">
                                <div class="cd-2fa-step-num">3</div>
                                <div style="flex:1;">
                                    <strong>Overte kód</strong>
                                    <p style="margin-bottom:10px;">Zadajte 6-miestny kód z aplikácie na overenie:</p>
                                    <div style="display:flex;gap:12px;align-items:end;">
                                        <input type="text" @bind="verifyCode" class="cd-input" maxlength="7" placeholder="000 000" style="text-align:center;letter-spacing:4px;font-weight:700;flex:1;" />
                                        <button @onclick="Verify2faSetup" class="cd-btn cd-btn-primary" disabled="@isLoading" style="height:44px;">Aktivovať</button>
                                    </div>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(twoFaMessage))
                            {
                                <div class="cd-alert @(twoFaSuccess ? "cd-alert-ok" : "cd-alert-err")" style="margin-top:16px;">
                                    @twoFaMessage
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="cd-2fa-status cd-2fa-inactive">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                            <div>
                                <strong>2FA nie je aktivované</strong>
                                <p>Pridajte ďalšiu vrstvu zabezpečenia pre váš účet.</p>
                            </div>
                        </div>

                        <button @onclick="Start2faSetup" class="cd-btn cd-btn-primary" style="width:100%;margin-top:20px;" disabled="@isLoading">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            Nastaviť dvojfaktorové overenie
                        </button>
                    }
                </div>
            </div>
        </div>
    }

    <div class="cd-main">
        <div class="cd-container">

            @if (userRole == "owner")
            {
                <!-- ===== MAJITEĽ VOZIDLA ===== -->
                <div class="cd-hero-card">
                    <div class="cd-hero-left">
                        <h1>Vitajte späť</h1>
                        <p>Prehľad vašich vozidiel a servisnej histórie</p>
                    </div>
                    <div class="cd-hero-right">
                        <button @onclick="() => showClaimVehicleForm = !showClaimVehicleForm" class="cd-btn cd-btn-ghost" style="color:white;border-color:rgba(255,255,255,0.3);">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
                            Prevziať vozidlo
                        </button>
                        <button @onclick="ShowAddVehicleModal" class="cd-btn cd-btn-accent">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            Pridať vozidlo
                        </button>
                    </div>
                </div>

                <!-- PREVZIAŤ VOZIDLO KÓDOM -->
                @if (showClaimVehicleForm)
                {
                    <div class="cd-section-card">
                        <div class="cd-section-head">
                            <h2>Prevziať vozidlo prenosovým kódom</h2>
                        </div>
                        <div class="cd-form-card">
                            <p style="color:var(--cd-gray);margin-bottom:16px;">Zadajte 8-miestny prenosový kód, ktorý ste dostali od aktuálneho majiteľa vozidla. Vozidlo aj s oprávneniami bude prenesené na váš účet.</p>
                            <div class="cd-form">
                                <div class="cd-form-row">
                                    <div class="cd-field">
                                        <label>Prenosový kód</label>
                                        <input type="text" @bind="claimTransferCode" class="cd-input" maxlength="8" placeholder="napr. A1B2C3D4" style="text-transform:uppercase;letter-spacing:3px;font-weight:700;font-size:18px;text-align:center;" />
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(claimMessage))
                                {
                                    <div class="cd-alert @(claimSuccess ? "cd-alert-ok" : "cd-alert-err")">
                                        @claimMessage
                                    </div>
                                }
                                <div class="cd-form-actions">
                                    <button type="button" @onclick="() => { showClaimVehicleForm = false; claimMessage = string.Empty; }" class="cd-btn cd-btn-ghost">Zrušiť</button>
                                    <button type="button" @onclick="ClaimVehicleByCode" class="cd-btn cd-btn-primary" disabled="@isLoading">
                                        @if (isLoading) { <span class="cd-spinner-sm"></span> <span>Overujem...</span> }
                                        else { <span>Prevziať vozidlo</span> }
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <!-- STAT CARDS -->
                <div class="cd-stats">
                    <div class="cd-stat-card">
                        <div class="cd-stat-icon blue">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0"/><path d="M17 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0"/><path d="M5 17H3v-6l2-5h9l4 5h1a2 2 0 0 1 2 2v4h-2"/><path d="M9 17h6"/></svg>
                        </div>
                        <div class="cd-stat-body">
                            <span class="cd-stat-value">@(vehicles?.Count ?? 0)</span>
                            <span class="cd-stat-label">Vozidlá</span>
                        </div>
                    </div>
                    <div class="cd-stat-card">
                        <div class="cd-stat-icon green">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="2"/></svg>
                        </div>
                        <div class="cd-stat-body">
                            <span class="cd-stat-value">@(serviceRecords?.Count ?? 0)</span>
                            <span class="cd-stat-label">Servisných záznamov</span>
                        </div>
                    </div>
                    <div class="cd-stat-card">
                        <div class="cd-stat-icon purple">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
                        </div>
                        <div class="cd-stat-body">
                            <span class="cd-stat-value">@GetRecentServices()</span>
                            <span class="cd-stat-label">Posledný mesiac</span>
                        </div>
                    </div>
                    <div class="cd-stat-card">
                        <div class="cd-stat-icon orange">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
                        </div>
                        <div class="cd-stat-body">
                            <span class="cd-stat-value">@GetTotalCost() €</span>
                            <span class="cd-stat-label">Celkové náklady</span>
                        </div>
                    </div>
                </div>

                <!-- VOZIDLÁ (CARD GRID) -->
                <div class="cd-section-card">
                    <div class="cd-section-head">
                        <h2>Moje vozidlá</h2>
                        <span class="cd-badge">@(vehicles?.Count ?? 0) vozidiel</span>
                    </div>

                    @if (vehicles == null || !vehicles.Any())
                    {
                        <div class="cd-empty">
                            <div class="cd-empty-icon">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5"><path d="M7 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0"/><path d="M17 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0"/><path d="M5 17H3v-6l2-5h9l4 5h1a2 2 0 0 1 2 2v4h-2"/><path d="M9 17h6"/></svg>
                            </div>
                            <h3>Žiadne vozidlá</h3>
                            <p>Pridajte svoje prvé vozidlo a začnite evidovať servisné záznamy</p>
                            <button @onclick="ShowAddVehicleModal" class="cd-btn cd-btn-primary">Pridať prvé vozidlo</button>
                        </div>
                    }
                    else
                    {
                        <div class="cd-vehicle-cards">
                            @foreach (var vehicle in vehicles)
                            {
                                <div class="cd-vehicle-card @(selectedVehicleId == vehicle.Id ? "active" : "")"
                                     @onclick="() => SelectVehicle(vehicle.Id)">
                                    <div class="cd-vc-top">
                                        <div class="cd-vc-icon">
                                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M7 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0"/><path d="M17 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0"/><path d="M5 17H3v-6l2-5h9l4 5h1a2 2 0 0 1 2 2v4h-2"/><path d="M9 17h6"/></svg>
                                        </div>
                                        <div class="cd-vc-status">
                                            <span class="cd-dot @GetStatusClass(vehicle)"></span>
                                            <span>@GetVehicleServiceStatus(vehicle)</span>
                                        </div>
                                    </div>
                                    <h3>@vehicle.Brand @vehicle.Model</h3>
                                    <div class="cd-vc-tags">
                                        <span class="cd-tag">@vehicle.Year</span>
                                        <span class="cd-tag">@vehicle.LicensePlate</span>
                                    </div>
                                    <p class="cd-vc-vin">VIN: @vehicle.VIN</p>
                                    <div class="cd-vc-footer">
                                        <span>@vehicle.ServiceRecords.Count záznamov</span>
                                        <div style="display:flex;gap:4px;">
                                            <button @onclick:stopPropagation @onclick="() => OpenReminderSettings(vehicle)" class="cd-btn-icon" title="Nastaviť pripomienky">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                                            </button>
                                            <button @onclick:stopPropagation @onclick="() => GenerateTransferCode(vehicle)" class="cd-btn-icon" title="Vygenerovať prenosový kód">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
                                            </button>
                                            <button @onclick:stopPropagation @onclick="() => StartEditVehicle(vehicle)" class="cd-btn-icon" title="Upraviť">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                            </button>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(vehicle.TransferCode) && vehicle.TransferCodeExpiry > DateTime.UtcNow)
                                    {
                                        <div class="cd-transfer-code-box" @onclick:stopPropagation>
                                            <span style="font-size:11px;color:var(--cd-gray);">Prenosový kód (platný do @vehicle.TransferCodeExpiry.Value.ToLocalTime().ToString("dd.MM. HH:mm")):</span>
                                            <span class="cd-transfer-code">@vehicle.TransferCode</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- SERVISNÁ HISTÓRIA -->
                <div class="cd-section-card">
                    <div class="cd-section-head">
                        <h2>História servisov</h2>
                        <div class="cd-head-actions">
                            <span class="cd-badge-outline">@(selectedVehicle != null ? $"{selectedVehicle.Brand} {selectedVehicle.Model}" : "Vyberte vozidlo")</span>
                            @if (selectedVehicle != null)
                            {
                                <a href="/api/export/pdf/@selectedVehicle.Id" target="_blank" class="cd-btn cd-btn-ghost cd-btn-sm" title="Export do PDF">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                    PDF
                                </a>
                                <button @onclick="() => showNewRecordForm = !showNewRecordForm" class="cd-btn cd-btn-primary cd-btn-sm">
                                    @if (showNewRecordForm) { <span>✕ Zrušiť</span> }
                                    else { <span>+ Nový záznam</span> }
                                </button>
                            }
                        </div>
                    </div>

                    @if (showNewRecordForm && selectedVehicle != null)
                    {
                        <div class="cd-form-card">
                            <h3>Nový servisný záznam</h3>
                            <EditForm Model="newServiceRecord" OnValidSubmit="SaveServiceRecord" class="cd-form">
                                <DataAnnotationsValidator />
                                <div class="cd-form-row">
                                    <div class="cd-field">
                                        <label>Dátum servisu *</label>
                                        <InputDate @bind-Value="newServiceRecord.ServiceDate" class="cd-input" />
                                        <ValidationMessage For="@(() => newServiceRecord.ServiceDate)" class="cd-error" />
                                    </div>
                                    <div class="cd-field">
                                        <label>Kilometrov *</label>
                                        <InputNumber @bind-Value="newServiceRecord.Mileage" class="cd-input" placeholder="125000" />
                                        <ValidationMessage For="@(() => newServiceRecord.Mileage)" class="cd-error" />
                                    </div>
                                </div>
                                <div class="cd-form-row">
                                    <div class="cd-field">
                                        <label>Typ servisu *</label>
                                        <InputSelect @bind-Value="newServiceRecord.ServiceType" class="cd-input">
                                            <option value="">-- Vyberte typ --</option>
                                            <option value="Pravidelný servis">Pravidelný servis</option>
                                            <option value="Oprava">Oprava</option>
                                            <option value="STK">STK</option>
                                            <option value="Emisná kontrola">Emisná kontrola</option>
                                            <option value="Výmena pneumatík">Výmena pneumatík</option>
                                            <option value="Diagnostika">Diagnostika</option>
                                            <option value="Iné">Iné</option>
                                        </InputSelect>
                                        <ValidationMessage For="@(() => newServiceRecord.ServiceType)" class="cd-error" />
                                    </div>
                                    <div class="cd-field">
                                        <label>Cena (€)</label>
                                        <InputNumber @bind-Value="newServiceRecord.Cost" class="cd-input" placeholder="150.00" />
                                    </div>
                                </div>
                                <div class="cd-field">
                                    <label>Popis prác *</label>
                                    <InputTextArea @bind-Value="newServiceRecord.Description" class="cd-textarea" placeholder="Výmena oleja, olejového filtra..." rows="3" />
                                    <ValidationMessage For="@(() => newServiceRecord.Description)" class="cd-error" />
                                </div>
                                <div class="cd-field">
                                    <label>Použité diely</label>
                                    <InputText @bind-Value="newServiceRecord.PartsUsed" class="cd-input" placeholder="Olej 5W30, Olejový filter Mann..." />
                                </div>
                                <div class="cd-field">
                                    <label>Poznámky</label>
                                    <InputTextArea @bind-Value="newServiceRecord.Notes" class="cd-textarea" placeholder="Dodatočné poznámky..." rows="2" />
                                </div>

                                @if (!string.IsNullOrEmpty(formMessage))
                                {
                                    <div class="cd-alert @(formSuccess ? "cd-alert-ok" : "cd-alert-err")">
                                        @formMessage
                                    </div>
                                }

                                <div class="cd-form-actions">
                                    <button type="button" @onclick="ClearForm" class="cd-btn cd-btn-ghost">Zrušiť</button>
                                    <button type="submit" class="cd-btn cd-btn-primary" disabled="@isLoading">
                                        @if (isLoading) { <span class="cd-spinner-sm"></span> <span>Ukladám...</span> }
                                        else { <span>Uložiť záznam</span> }
                                    </button>
                                </div>
                            </EditForm>
                        </div>
                    }

                    @if (selectedVehicle == null)
                    {
                        <div class="cd-empty">
                            <div class="cd-empty-icon">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5"><path d="M8 7l4-4 4 4"/><path d="M12 3v13"/><path d="M5 21h14"/></svg>
                            </div>
                            <h3>Vyberte vozidlo</h3>
                            <p>Kliknite na vozidlo vyššie pre zobrazenie histórie servisov</p>
                        </div>
                    }
                    else if (serviceRecords == null || !serviceRecords.Any())
                    {
                        <div class="cd-empty">
                            <div class="cd-empty-icon">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="2"/></svg>
                            </div>
                            <h3>Žiadne záznamy</h3>
                            <p>Pre toto vozidlo ešte nie sú evidované žiadne servisné záznamy</p>
                        </div>
                    }
                    else
                    {
                        <div class="cd-record-cards">
                            @foreach (var record in serviceRecords.OrderByDescending(r => r.ServiceDate))
                            {
                                <div class="cd-record-card">
                                    <div class="cd-rc-date">
                                        <span class="cd-rc-day">@record.ServiceDate.Day</span>
                                        <span class="cd-rc-month">@record.ServiceDate.ToString("MMM yyyy")</span>
                                    </div>
                                    <div class="cd-rc-body">
                                        <div class="cd-rc-top">
                                            <h4>@record.ServiceType</h4>
                                            <span class="cd-tag">@record.Mileage.ToString("N0") km</span>
                                        </div>
                                        <p class="cd-rc-desc">@record.Description</p>
                                        @if (!string.IsNullOrEmpty(record.PartsUsed))
                                        {
                                            <p class="cd-rc-parts">Diely: @record.PartsUsed</p>
                                        }
                                        @if (record.Cost.HasValue)
                                        {
                                            <span class="cd-price-tag">@record.Cost.Value.ToString("N2") €</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- OPRÁVNENIA SERVISOV -->
                <div class="cd-section-card">
                    <div class="cd-section-head">
                        <h2>Oprávnenia servisov</h2>
                        <button @onclick="() => showGrantPermissionForm = !showGrantPermissionForm" class="cd-btn cd-btn-primary cd-btn-sm">
                            @if (showGrantPermissionForm) { <span>✕ Zrušiť</span> }
                            else { <span>+ Pridať oprávnenie</span> }
                        </button>
                    </div>

                    @if (showGrantPermissionForm)
                    {
                        <div class="cd-form-card">
                            <h3>Prideliť prístup servisu k vozidlu</h3>
                            <div class="cd-form">
                                <div class="cd-form-row">
                                    <div class="cd-field">
                                        <label>Vozidlo</label>
                                        <select @bind="permissionVehicleId" class="cd-input">
                                            <option value="0">-- Vyberte vozidlo --</option>
                                            @if (vehicles != null)
                                            {
                                                @foreach (var v in vehicles)
                                                {
                                                    <option value="@v.Id">@v.Brand @v.Model (@v.LicensePlate)</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="cd-field">
                                        <label>E-mail servisu</label>
                                        <input type="email" @bind="permissionServiceEmail" class="cd-input" placeholder="servis@autoservis.sk" />
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(permissionMessage))
                                {
                                    <div class="cd-alert @(permissionSuccess ? "cd-alert-ok" : "cd-alert-err")">
                                        @permissionMessage
                                    </div>
                                }
                                <div class="cd-form-actions">
                                    <button type="button" @onclick="GrantPermission" class="cd-btn cd-btn-primary">Prideliť oprávnenie</button>
                                </div>
                            </div>
                        </div>
                    }

                    @if (vehiclePermissions != null && vehiclePermissions.Any())
                    {
                        <div class="cd-record-cards">
                            @foreach (var perm in vehiclePermissions)
                            {
                                <div class="cd-record-card compact">
                                    <div class="cd-rc-date sm" style="background: var(--cd-green);">
                                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
                                    </div>
                                    <div class="cd-rc-body">
                                        <div class="cd-rc-top">
                                            <h4>@perm.Service.FullName</h4>
                                            <span class="cd-tag-sm">@perm.Vehicle.Brand @perm.Vehicle.Model</span>
                                        </div>
                                        <p class="cd-rc-desc">@perm.Service.Email — od @perm.GrantedAt.ToString("dd.MM.yyyy")</p>
                                    </div>
                                    <button @onclick="() => RevokePermission(perm.Id)" class="cd-btn-icon danger" title="Odobrať">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    else if (!showGrantPermissionForm)
                    {
                        <div class="cd-empty">
                            <h3>Žiadne oprávnenia</h3>
                            <p>Zatiaľ ste nepridelili prístup žiadnemu servisu</p>
                        </div>
                    }
                </div>
            }
            else if (userRole == "service")
            {
                <!-- ===== AUTOSERVIS ===== -->
                <div class="cd-hero-card">
                    <div class="cd-hero-left">
                        <h1>@(currentServiceProfile?.CompanyName ?? "Autoservis Dashboard")</h1>
                        <p>@(currentServiceProfile != null ? $"{currentServiceProfile.Address}, {currentServiceProfile.PostalCode} {currentServiceProfile.City}" : "Správa klientskych vozidiel a servisných záznamov")</p>
                    </div>
                    <div class="cd-hero-right">
                        <button @onclick="() => showServiceProfileForm = !showServiceProfileForm" class="cd-btn cd-btn-accent">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            Profil servisu
                        </button>
                    </div>
                </div>

                <!-- PROFIL SERVISU FORMULÁR -->
                @if (showServiceProfileForm)
                {
                    <div class="cd-section-card">
                        <div class="cd-section-head">
                            <h2>Profil autoservisu</h2>
                        </div>
                        <div class="cd-form-card">
                            <div class="cd-form">
                                <div class="cd-form-row">
                                    <div class="cd-field">
                                        <label>Názov firmy *</label>
                                        <input type="text" @bind="svcFormCompanyName" class="cd-input" placeholder="AutoServis Bratislava s.r.o." />
                                    </div>
                                    <div class="cd-field">
                                        <label>IČO</label>
                                        <input type="text" @bind="svcFormICO" class="cd-input" placeholder="12345678" />
                                    </div>
                                </div>
                                <div class="cd-form-row">
                                    <div class="cd-field">
                                        <label>Adresa</label>
                                        <input type="text" @bind="svcFormAddress" class="cd-input" placeholder="Hlavná 15" />
                                    </div>
                                    <div class="cd-field">
                                        <label>Mesto</label>
                                        <input type="text" @bind="svcFormCity" class="cd-input" placeholder="Bratislava" />
                                    </div>
                                </div>
                                <div class="cd-form-row">
                                    <div class="cd-field">
                                        <label>PSČ</label>
                                        <input type="text" @bind="svcFormPostalCode" class="cd-input" placeholder="81101" />
                                    </div>
                                    <div class="cd-field">
                                        <label>Telefón</label>
                                        <input type="text" @bind="svcFormPhone" class="cd-input" placeholder="+421 2 1234 5678" />
                                    </div>
                                </div>
                                <div class="cd-form-row">
                                    <div class="cd-field">
                                        <label>Kontaktný e-mail</label>
                                        <input type="email" @bind="svcFormContactEmail" class="cd-input" placeholder="servis@firma.sk" />
                                    </div>
                                </div>
                                <div class="cd-field">
                                    <label>Popis služieb</label>
                                    <textarea @bind="svcFormDescription" class="cd-input" rows="3" placeholder="Popis vašich služieb..."></textarea>
                                </div>
                                @if (!string.IsNullOrEmpty(svcFormMessage))
                                {
                                    <div class="cd-alert @(svcFormSuccess ? "cd-alert-ok" : "cd-alert-err")">
                                        @svcFormMessage
                                    </div>
                                }
                                <div class="cd-form-actions">
                                    <button type="button" @onclick="() => showServiceProfileForm = false" class="cd-btn cd-btn-ghost">Zavrieť</button>
                                    <button type="button" @onclick="SaveServiceProfile" class="cd-btn cd-btn-primary" disabled="@isLoading">Uložiť profil</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="cd-stats">
                    <div class="cd-stat-card">
                        <div class="cd-stat-icon blue">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0"/><path d="M17 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0"/><path d="M5 17H3v-6l2-5h9l4 5h1a2 2 0 0 1 2 2v4h-2"/><path d="M9 17h6"/></svg>
                        </div>
                        <div class="cd-stat-body">
                            <span class="cd-stat-value">@(vehicles?.Count ?? 0)</span>
                            <span class="cd-stat-label">Prístupné vozidlá</span>
                        </div>
                    </div>
                    <div class="cd-stat-card">
                        <div class="cd-stat-icon green">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                        </div>
                        <div class="cd-stat-body">
                            <span class="cd-stat-value">@GetRecentServices()</span>
                            <span class="cd-stat-label">Dokončené tento mesiac</span>
                        </div>
                    </div>
                    <div class="cd-stat-card">
                        <div class="cd-stat-icon purple">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="2"/></svg>
                        </div>
                        <div class="cd-stat-body">
                            <span class="cd-stat-value">@(serviceRecords?.Count ?? 0)</span>
                            <span class="cd-stat-label">Celkovo záznamov</span>
                        </div>
                    </div>
                    <div class="cd-stat-card">
                        <div class="cd-stat-icon orange">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                        </div>
                        <div class="cd-stat-body">
                            <span class="cd-stat-value">@GetUniqueCustomers()</span>
                            <span class="cd-stat-label">Klientov</span>
                        </div>
                    </div>
                </div>

                <div class="cd-two-col">
                    <!-- KLIENTSKE VOZIDLÁ -->
                    <div class="cd-section-card">
                        <div class="cd-section-head">
                            <h2>Klientske vozidlá</h2>
                            <span class="cd-badge">@(vehicles?.Count ?? 0)</span>
                        </div>

                        @if (vehicles == null || !vehicles.Any())
                        {
                            <div class="cd-empty">
                                <div class="cd-empty-icon">
                                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5"><path d="M7 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0"/><path d="M17 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0"/><path d="M5 17H3v-6l2-5h9l4 5h1a2 2 0 0 1 2 2v4h-2"/><path d="M9 17h6"/></svg>
                                </div>
                                <h3>Žiadne vozidlá</h3>
                                <p>Zatiaľ vám neboli udelené prístupové práva k žiadnym vozidlám</p>
                            </div>
                        }
                        else
                        {
                            <div class="cd-vehicle-list">
                                @foreach (var vehicle in vehicles)
                                {
                                    <div class="cd-vehicle-card-compact @(selectedVehicleId == vehicle.Id ? "active" : "")"
                                         @onclick="() => SelectVehicle(vehicle.Id)">
                                        <div class="cd-vcc-icon">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M7 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0"/><path d="M17 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0"/><path d="M5 17H3v-6l2-5h9l4 5h1a2 2 0 0 1 2 2v4h-2"/><path d="M9 17h6"/></svg>
                                        </div>
                                        <div class="cd-vcc-info">
                                            <h4>@vehicle.Brand @vehicle.Model</h4>
                                            <div class="cd-vc-tags">
                                                <span class="cd-tag-sm">@vehicle.Year</span>
                                                <span class="cd-tag-sm">@vehicle.LicensePlate</span>
                                            </div>
                                            <span class="cd-vcc-owner">@vehicle.Owner.FullName</span>
                                        </div>
                                        <div class="cd-vcc-count">
                                            <span class="cd-count-num">@vehicle.ServiceRecords.Count</span>
                                            <span class="cd-count-label">záznamov</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <!-- FORMULÁR + HISTÓRIA -->
                    <div class="cd-section-card">
                        <div class="cd-section-head">
                            <h2>Servisný záznam</h2>
                            <span class="cd-badge-outline">@(selectedVehicle != null ? $"{selectedVehicle.Brand} {selectedVehicle.Model}" : "Vyberte vozidlo")</span>
                        </div>

                        @if (selectedVehicle == null)
                        {
                            <div class="cd-empty">
                                <div class="cd-empty-icon">
                                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
                                </div>
                                <h3>Vyberte vozidlo</h3>
                                <p>Najprv vyberte vozidlo klienta z ľavej strany</p>
                            </div>
                        }
                        else
                        {
                            <div class="cd-form-card">
                                <EditForm Model="newServiceRecord" OnValidSubmit="SaveServiceRecord" class="cd-form">
                                    <DataAnnotationsValidator />
                                    <div class="cd-form-row">
                                        <div class="cd-field">
                                            <label>Dátum servisu *</label>
                                            <InputDate @bind-Value="newServiceRecord.ServiceDate" class="cd-input" />
                                            <ValidationMessage For="@(() => newServiceRecord.ServiceDate)" class="cd-error" />
                                        </div>
                                        <div class="cd-field">
                                            <label>Stav kilometrov *</label>
                                            <InputNumber @bind-Value="newServiceRecord.Mileage" class="cd-input" placeholder="125000" />
                                            <ValidationMessage For="@(() => newServiceRecord.Mileage)" class="cd-error" />
                                        </div>
                                    </div>
                                    <div class="cd-form-row">
                                        <div class="cd-field">
                                            <label>Typ servisu *</label>
                                            <InputSelect @bind-Value="newServiceRecord.ServiceType" class="cd-input">
                                                <option value="">-- Vyberte typ --</option>
                                                <option value="Pravidelný servis">Pravidelný servis</option>
                                                <option value="Oprava">Oprava</option>
                                                <option value="STK">STK</option>
                                                <option value="Emisná kontrola">Emisná kontrola</option>
                                                <option value="Výmena pneumatík">Výmena pneumatík</option>
                                                <option value="Diagnostika">Diagnostika</option>
                                                <option value="Iné">Iné</option>
                                            </InputSelect>
                                            <ValidationMessage For="@(() => newServiceRecord.ServiceType)" class="cd-error" />
                                        </div>
                                        <div class="cd-field">
                                            <label>Cena (€)</label>
                                            <InputNumber @bind-Value="newServiceRecord.Cost" class="cd-input" placeholder="150.00" />
                                        </div>
                                    </div>
                                    <div class="cd-field">
                                        <label>Vykonané práce *</label>
                                        <InputTextArea @bind-Value="newServiceRecord.Description" class="cd-textarea" placeholder="Podrobný popis vykonaných prác..." rows="3" />
                                        <ValidationMessage For="@(() => newServiceRecord.Description)" class="cd-error" />
                                    </div>
                                    <div class="cd-field">
                                        <label>Použité náhradné diely</label>
                                        <InputText @bind-Value="newServiceRecord.PartsUsed" class="cd-input" placeholder="Olej Castrol 5W30, Olejový filter Mann..." />
                                    </div>
                                    <div class="cd-field">
                                        <label>Interné poznámky</label>
                                        <InputTextArea @bind-Value="newServiceRecord.Notes" class="cd-textarea" placeholder="Odporúčania, pozorovania..." rows="2" />
                                    </div>

                                    @if (!string.IsNullOrEmpty(formMessage))
                                    {
                                        <div class="cd-alert @(formSuccess ? "cd-alert-ok" : "cd-alert-err")">
                                            @formMessage
                                        </div>
                                    }

                                    <div class="cd-form-actions">
                                        <button type="button" @onclick="ClearForm" class="cd-btn cd-btn-ghost">Vyčistiť</button>
                                        <button type="submit" class="cd-btn cd-btn-primary" disabled="@isLoading">
                                            @if (isLoading) { <span class="cd-spinner-sm"></span> <span>Ukladám...</span> }
                                            else { <span>Uložiť záznam</span> }
                                        </button>
                                    </div>
                                </EditForm>
                            </div>

                            @if (serviceRecords != null && serviceRecords.Any())
                            {
                                <div class="cd-divider"></div>
                                <h3 class="cd-sub-title">Posledné záznamy</h3>
                                <div class="cd-record-cards">
                                    @foreach (var record in serviceRecords.OrderByDescending(r => r.ServiceDate).Take(5))
                                    {
                                        <div class="cd-record-card compact">
                                            <div class="cd-rc-date sm">
                                                <span class="cd-rc-day">@record.ServiceDate.Day</span>
                                                <span class="cd-rc-month">@record.ServiceDate.ToString("MMM")</span>
                                            </div>
                                            <div class="cd-rc-body">
                                                <div class="cd-rc-top">
                                                    <h4>@record.Vehicle.Brand @record.Vehicle.Model</h4>
                                                    <span class="cd-tag-sm">@record.ServiceType</span>
                                                </div>
                                                <p class="cd-rc-desc">@record.Description</p>
                                                <span class="cd-rc-meta">@record.CreatedBy.FullName</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>

                <!-- ODOSLAŤ PRIPOMIENKU MAJITEĽOVI -->
                @if (selectedVehicle != null)
                {
                    <div class="cd-section-card">
                        <div class="cd-section-head">
                            <h2>Odoslať pripomienku majiteľovi</h2>
                            <button @onclick="() => showServiceReminderForm = !showServiceReminderForm" class="cd-btn cd-btn-sm cd-btn-ghost">
                                @(showServiceReminderForm ? "Skryť" : "Nová pripomienka")
                            </button>
                        </div>
                        @if (showServiceReminderForm)
                        {
                            <div class="cd-form-card">
                                <div class="cd-form">
                                    <div class="cd-reminder-info" style="margin-bottom:16px;">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0369a1" stroke-width="2" style="flex-shrink:0;"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
                                        <p>Odošlite pripomienku majiteľovi vozidla <strong>@selectedVehicle.Brand @selectedVehicle.Model</strong> (@selectedVehicle.Owner.FullName).</p>
                                    </div>
                                    <div class="cd-form-row">
                                        <div class="cd-field">
                                            <label>Titulok pripomienky *</label>
                                            <input type="text" @bind="svcReminderTitle" class="cd-input" placeholder="Napr. Výmena oleja, Ďalší servis..." />
                                        </div>
                                        <div class="cd-field">
                                            <label>Typ</label>
                                            <select @bind="svcReminderCategory" class="cd-input">
                                                <option value="service">Servis</option>
                                                <option value="stk">STK</option>
                                                <option value="emission">Emisná kontrola</option>
                                                <option value="insurance">Poistenie</option>
                                                <option value="custom">Iné</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="cd-field">
                                        <label>Správa</label>
                                        <textarea @bind="svcReminderMessage" class="cd-textarea" rows="3" placeholder="Podrobnosti pripomienky..."></textarea>
                                    </div>

                                    @if (!string.IsNullOrEmpty(svcReminderFormMessage))
                                    {
                                        <div class="cd-alert @(svcReminderFormSuccess ? "cd-alert-ok" : "cd-alert-err")">
                                            @svcReminderFormMessage
                                        </div>
                                    }
                                    <div class="cd-form-actions">
                                        <button type="button" @onclick="() => showServiceReminderForm = false" class="cd-btn cd-btn-ghost">Zrušiť</button>
                                        <button type="button" @onclick="SendServiceReminder" class="cd-btn cd-btn-primary" disabled="@isLoading">Odoslať pripomienku</button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else if (userRole == "admin")
            {
                <!-- ===== ADMINISTRÁTOR ===== -->
                <div class="cd-hero-card admin-hero">
                    <div class="cd-hero-left">
                        <h1>Administrátorský panel</h1>
                        <p>Kompletný prehľad systému a používateľov</p>
                    </div>
                    <div class="cd-hero-right">
                        <button @onclick="() => showAdminCreateUserForm = !showAdminCreateUserForm" class="cd-btn cd-btn-accent">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            Pridať používateľa
                        </button>
                    </div>
                </div>

                <div class="cd-stats">
                    <div class="cd-stat-card">
                        <div class="cd-stat-icon blue">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                        </div>
                        <div class="cd-stat-body">
                            <span class="cd-stat-value">@GetTotalUsers()</span>
                            <span class="cd-stat-label">Celkovo používateľov</span>
                        </div>
                    </div>
                    <div class="cd-stat-card">
                        <div class="cd-stat-icon green">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0"/><path d="M17 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0"/><path d="M5 17H3v-6l2-5h9l4 5h1a2 2 0 0 1 2 2v4h-2"/><path d="M9 17h6"/></svg>
                        </div>
                        <div class="cd-stat-body">
                            <span class="cd-stat-value">@GetTotalVehicles()</span>
                            <span class="cd-stat-label">Registrovaných vozidiel</span>
                        </div>
                    </div>
                    <div class="cd-stat-card">
                        <div class="cd-stat-icon purple">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="2"/></svg>
                        </div>
                        <div class="cd-stat-body">
                            <span class="cd-stat-value">@GetTotalRecords()</span>
                            <span class="cd-stat-label">Servisných záznamov</span>
                        </div>
                    </div>
                    <div class="cd-stat-card">
                        <div class="cd-stat-icon orange">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
                        </div>
                        <div class="cd-stat-body">
                            <span class="cd-stat-value">@GetTotalServices()</span>
                            <span class="cd-stat-label">Autoservisov</span>
                        </div>
                    </div>
                </div>

                <!-- POUŽÍVATELIA - CARD GRID -->
                <div class="cd-section-card">
                    <div class="cd-section-head">
                        <h2>Používatelia</h2>
                        <span class="cd-badge">@(allUsers?.Count ?? 0) registrovaných</span>
                    </div>

                    @if (showAdminCreateUserForm)
                    {
                        <div class="cd-form-card">
                            <h3>Nový používateľ</h3>
                            <div class="cd-form">
                                <div class="cd-form-row">
                                    <div class="cd-field">
                                        <label>Meno *</label>
                                        <input type="text" @bind="adminNewFirstName" class="cd-input" placeholder="Ján" />
                                    </div>
                                    <div class="cd-field">
                                        <label>Priezvisko *</label>
                                        <input type="text" @bind="adminNewLastName" class="cd-input" placeholder="Novák" />
                                    </div>
                                </div>
                                <div class="cd-form-row">
                                    <div class="cd-field">
                                        <label>E-mail *</label>
                                        <input type="email" @bind="adminNewEmail" class="cd-input" placeholder="email@priklad.sk" />
                                    </div>
                                    <div class="cd-field">
                                        <label>Heslo *</label>
                                        <input type="password" @bind="adminNewPassword" class="cd-input" placeholder="Min. 6 znakov" />
                                    </div>
                                </div>
                                <div class="cd-field">
                                    <label>Rola *</label>
                                    <select @bind="adminNewRole" class="cd-input">
                                        <option value="Owner">Majiteľ vozidla</option>
                                        <option value="Service">Autoservis</option>
                                        <option value="Admin">Administrátor</option>
                                    </select>
                                </div>
                                @if (!string.IsNullOrEmpty(adminUserMessage))
                                {
                                    <div class="cd-alert @(adminUserSuccess ? "cd-alert-ok" : "cd-alert-err")">
                                        @adminUserMessage
                                    </div>
                                }
                                <div class="cd-form-actions">
                                    <button type="button" @onclick="() => showAdminCreateUserForm = false" class="cd-btn cd-btn-ghost">Zrušiť</button>
                                    <button type="button" @onclick="AdminCreateUser" class="cd-btn cd-btn-primary" disabled="@isLoading">Vytvoriť používateľa</button>
                                </div>
                            </div>
                        </div>
                    }

                    @if (allUsers != null && allUsers.Any())
                    {
                        <div class="cd-user-cards">
                            @foreach (var user in allUsers)
                            {
                                <div class="cd-user-card">
                                    <div class="cd-uc-top">
                                        <div class="cd-uc-avatar">@GetInitials(user.FirstName, user.LastName)</div>
                                        <span class="cd-role-pill @GetRoleBadgeClass(user.Role)">@GetRoleName(user.Role)</span>
                                    </div>
                                    <h4 class="cd-uc-name">@user.FullName</h4>
                                    <p class="cd-uc-email">@user.Email</p>
                                    <div class="cd-uc-stats">
                                        <div class="cd-uc-stat">
                                            <span class="cd-uc-stat-val">@user.OwnedVehicles.Count</span>
                                            <span class="cd-uc-stat-lbl">Vozidiel</span>
                                        </div>
                                        <div class="cd-uc-stat">
                                            <span class="cd-uc-stat-val">@user.CreatedServiceRecords.Count</span>
                                            <span class="cd-uc-stat-lbl">Záznamov</span>
                                        </div>
                                    </div>
                                    <div class="cd-uc-footer">
                                        <span class="cd-uc-date">@user.CreatedAt.ToString("dd.MM.yyyy")</span>
                                        @if (user.IsActive)
                                        {
                                            <span class="cd-status-pill active">Aktívny</span>
                                        }
                                        else
                                        {
                                            <span class="cd-status-pill inactive">Neaktívny</span>
                                        }
                                    </div>
                                    <div class="cd-uc-actions">
                                        <button @onclick="() => StartEditUser(user)" class="cd-btn-icon" title="Upraviť">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                        </button>
                                        @if (user.IsActive)
                                        {
                                            <button @onclick="() => AdminToggleUserActive(user.Id, false)" class="cd-btn-icon danger" title="Deaktivovať">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                                            </button>
                                        }
                                        else
                                        {
                                            <button @onclick="() => AdminToggleUserActive(user.Id, true)" class="cd-btn-icon success" title="Aktivovať">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="cd-two-col">
                    <!-- VOZIDLÁ -->
                    <div class="cd-section-card">
                        <div class="cd-section-head">
                            <h2>Všetky vozidlá</h2>
                            <span class="cd-badge">@(allVehicles?.Count ?? 0)</span>
                        </div>

                        @if (allVehicles != null && allVehicles.Any())
                        {
                            <div class="cd-vehicle-cards">
                                @foreach (var vehicle in allVehicles.Take(6))
                                {
                                    <div class="cd-vehicle-card" @onclick="() => SelectVehicle(vehicle.Id)">
                                        <div class="cd-vc-top">
                                            <div class="cd-vc-icon">
                                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M7 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0"/><path d="M17 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0"/><path d="M5 17H3v-6l2-5h9l4 5h1a2 2 0 0 1 2 2v4h-2"/><path d="M9 17h6"/></svg>
                                            </div>
                                            <div class="cd-vc-status">
                                                <span>@vehicle.ServiceRecords.Count záznamov</span>
                                            </div>
                                        </div>
                                        <h3>@vehicle.Brand @vehicle.Model</h3>
                                        <div class="cd-vc-tags">
                                            <span class="cd-tag">@vehicle.Year</span>
                                            <span class="cd-tag">@vehicle.LicensePlate</span>
                                        </div>
                                        <p class="cd-vc-vin">@vehicle.Owner.FullName</p>
                                    </div>
                                }
                            </div>
                            @if (allVehicles.Count > 6)
                            {
                                <p class="cd-more-text">... a ďalších @(allVehicles.Count - 6) vozidiel</p>
                            }
                        }
                    </div>

                    <!-- NEDÁVNA AKTIVITA -->
                    <div class="cd-section-card">
                        <div class="cd-section-head">
                            <h2>Nedávna aktivita</h2>
                            <span class="cd-badge">posledných @(recentRecords?.Count ?? 0)</span>
                        </div>

                        @if (recentRecords != null && recentRecords.Any())
                        {
                            <div class="cd-record-cards">
                                @foreach (var record in recentRecords.Take(10))
                                {
                                    <div class="cd-record-card compact">
                                        <div class="cd-rc-date sm">
                                            <span class="cd-rc-day">@record.ServiceDate.Day</span>
                                            <span class="cd-rc-month">@record.ServiceDate.ToString("MMM")</span>
                                        </div>
                                        <div class="cd-rc-body">
                                            <div class="cd-rc-top">
                                                <h4>@record.Vehicle.Brand @record.Vehicle.Model</h4>
                                                <span class="cd-tag-sm">@record.ServiceType</span>
                                            </div>
                                            <p class="cd-rc-desc">@record.Description</p>
                                            <span class="cd-rc-meta">@record.CreatedBy.FullName</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- ZOZNAM SERVISOV (Services tabuľka) -->
                <div class="cd-section-card">
                    <div class="cd-section-head">
                        <h2>Autoservisy</h2>
                        <span class="cd-badge">@(allServicesData?.Count ?? 0) registrovaných</span>
                    </div>

                    @if (allServicesData != null && allServicesData.Any())
                    {
                        <div class="cd-user-cards">
                            @foreach (var svc in allServicesData)
                            {
                                <div class="cd-user-card">
                                    <div class="cd-uc-top">
                                        <div class="cd-uc-avatar" style="background: linear-gradient(135deg, #f97316, #ef4444);">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
                                        </div>
                                        <span class="cd-role-pill service">Servis</span>
                                    </div>
                                    <h4 class="cd-uc-name">@svc.CompanyName</h4>
                                    <p class="cd-uc-email">@svc.User.FullName</p>
                                    @if (!string.IsNullOrEmpty(svc.ICO))
                                    {
                                        <p class="cd-uc-email" style="margin-top:2px;">IČO: @svc.ICO</p>
                                    }
                                    <div class="cd-uc-stats">
                                        <div class="cd-uc-stat">
                                            <span class="cd-uc-stat-val">@(svc.City ?? "—")</span>
                                            <span class="cd-uc-stat-lbl">Mesto</span>
                                        </div>
                                        <div class="cd-uc-stat">
                                            <span class="cd-uc-stat-val">@(svc.Phone ?? "—")</span>
                                            <span class="cd-uc-stat-lbl">Telefón</span>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(svc.Address))
                                    {
                                        <p class="cd-uc-email" style="font-size:12px;margin-top:6px;">@svc.Address, @svc.PostalCode @svc.City</p>
                                    }
                                    @if (!string.IsNullOrEmpty(svc.Description))
                                    {
                                        <p class="cd-uc-email" style="font-size:11px;margin-top:4px;color:#94a3b8;">@svc.Description</p>
                                    }
                                    <div class="cd-uc-footer">
                                        <span class="cd-uc-date">@svc.CreatedAt.ToString("dd.MM.yyyy")</span>
                                        @if (svc.IsActive)
                                        {
                                            <span class="cd-status-pill active">Aktívny</span>
                                        }
                                        else
                                        {
                                            <span class="cd-status-pill inactive">Neaktívny</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="cd-empty">
                            <h3>Žiadne servisy</h3>
                            <p>V systéme nie sú registrované žiadne servisné prevádzky</p>
                        </div>
                    }
                </div>

                <!-- SPRÁVA OPRÁVNENÍ (ADMIN) -->
                <div class="cd-section-card">
                    <div class="cd-section-head">
                        <h2>Oprávnenia servisov</h2>
                        <button @onclick="() => showAdminPermissionForm = !showAdminPermissionForm" class="cd-btn cd-btn-primary cd-btn-sm">
                            @if (showAdminPermissionForm) { <span>✕ Zrušiť</span> }
                            else { <span>+ Prideliť oprávnenie</span> }
                        </button>
                    </div>

                    @if (showAdminPermissionForm)
                    {
                        <div class="cd-form-card">
                            <h3>Prideliť servisu prístup k vozidlu</h3>
                            <div class="cd-form">
                                <div class="cd-form-row">
                                    <div class="cd-field">
                                        <label>Servis (e-mail)</label>
                                        <input type="email" @bind="adminPermServiceEmail" class="cd-input" placeholder="servis@autoservis.sk" />
                                    </div>
                                    <div class="cd-field">
                                        <label>Vozidlo</label>
                                        <select @bind="adminPermVehicleId" class="cd-input">
                                            <option value="0">-- Vyberte vozidlo --</option>
                                            @if (allVehicles != null)
                                            {
                                                @foreach (var v in allVehicles)
                                                {
                                                    <option value="@v.Id">@v.Brand @v.Model (@v.LicensePlate) - @v.Owner.FullName</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(adminPermMessage))
                                {
                                    <div class="cd-alert @(adminPermSuccess ? "cd-alert-ok" : "cd-alert-err")">
                                        @adminPermMessage
                                    </div>
                                }
                                <div class="cd-form-actions">
                                    <button type="button" @onclick="AdminGrantPermission" class="cd-btn cd-btn-primary">Prideliť</button>
                                </div>
                            </div>
                        </div>
                    }

                    @if (allPermissions != null && allPermissions.Any())
                    {
                        <div class="cd-record-cards">
                            @foreach (var perm in allPermissions)
                            {
                                <div class="cd-record-card compact">
                                    <div class="cd-rc-date sm" style="background: var(--cd-green);">
                                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
                                    </div>
                                    <div class="cd-rc-body">
                                        <div class="cd-rc-top">
                                            <h4>@perm.Service.FullName → @perm.Vehicle.Brand @perm.Vehicle.Model</h4>
                                            <span class="cd-tag-sm">@perm.Vehicle.LicensePlate</span>
                                        </div>
                                        <p class="cd-rc-desc">@perm.Service.Email — od @perm.GrantedAt.ToString("dd.MM.yyyy") — @(perm.IsActive ? "Aktívne" : "Neaktívne")</p>
                                    </div>
                                    @if (perm.IsActive)
                                    {
                                        <button @onclick="() => AdminRevokePermission(perm.Id)" class="cd-btn-icon danger" title="Odobrať">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else if (!showAdminPermissionForm)
                    {
                        <div class="cd-empty">
                            <h3>Žiadne oprávnenia</h3>
                            <p>V systéme zatiaľ nie sú pridelené žiadne oprávnenia</p>
                        </div>
                    }
                </div>
            }

        </div>
    </div>

    <!-- ====== MODÁLY ====== -->

    @if (showVehicleForm)
    {
        <div class="cd-modal-overlay" @onclick="() => showVehicleForm = false">
            <div class="cd-modal" @onclick:stopPropagation>
                <div class="cd-modal-header">
                    <h2>@(editingVehicleId > 0 ? "Upraviť vozidlo" : "Nové vozidlo")</h2>
                    <button @onclick="() => showVehicleForm = false" class="cd-modal-close">✕</button>
                </div>
                <div class="cd-form">
                    <div class="cd-form-row">
                        <div class="cd-field">
                            <label>VIN (17 znakov) *</label>
                            <input type="text" @bind="vehicleFormVin" class="cd-input" maxlength="17" placeholder="WVWZZZ1JZ3W386752" />
                        </div>
                        <div class="cd-field">
                            <label>ŠPZ *</label>
                            <input type="text" @bind="vehicleFormPlate" class="cd-input" placeholder="BA123AB" />
                        </div>
                    </div>
                    <div class="cd-form-row">
                        <div class="cd-field">
                            <label>Značka *</label>
                            <input type="text" @bind="vehicleFormBrand" class="cd-input" placeholder="Volkswagen" />
                        </div>
                        <div class="cd-field">
                            <label>Model *</label>
                            <input type="text" @bind="vehicleFormModel" class="cd-input" placeholder="Golf" />
                        </div>
                    </div>
                    <div class="cd-form-row">
                        <div class="cd-field">
                            <label>Rok výroby *</label>
                            <input type="number" @bind="vehicleFormYear" class="cd-input" min="1900" max="2100" />
                        </div>
                        <div class="cd-field">
                            <label>Farba</label>
                            <input type="text" @bind="vehicleFormColor" class="cd-input" placeholder="Modrá" />
                        </div>
                    </div>
                    <div class="cd-form-row">
                        <div class="cd-field">
                            <label>Typ motora</label>
                            <input type="text" @bind="vehicleFormEngine" class="cd-input" placeholder="1.5 TSI" />
                        </div>
                        <div class="cd-field">
                            <label>Výkon (kW)</label>
                            <input type="number" @bind="vehicleFormPower" class="cd-input" placeholder="110" />
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(vehicleFormMessage))
                    {
                        <div class="cd-alert @(vehicleFormSuccess ? "cd-alert-ok" : "cd-alert-err")">
                            @vehicleFormMessage
                        </div>
                    }
                    <div class="cd-form-actions">
                        <button type="button" @onclick="() => showVehicleForm = false" class="cd-btn cd-btn-ghost">Zrušiť</button>
                        <button type="button" @onclick="SaveVehicle" class="cd-btn cd-btn-primary" disabled="@isLoading">
                            @if (isLoading) { <span class="cd-spinner-sm"></span> }
                            <span>@(editingVehicleId > 0 ? "Uložiť zmeny" : "Pridať vozidlo")</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (showEditUserModal)
    {
        <div class="cd-modal-overlay" @onclick="() => showEditUserModal = false">
            <div class="cd-modal" @onclick:stopPropagation>
                <div class="cd-modal-header">
                    <h2>Upraviť používateľa</h2>
                    <button @onclick="() => showEditUserModal = false" class="cd-modal-close">✕</button>
                </div>
                <div class="cd-form">
                    <div class="cd-form-row">
                        <div class="cd-field">
                            <label>Meno</label>
                            <input type="text" @bind="editUserFirstName" class="cd-input" />
                        </div>
                        <div class="cd-field">
                            <label>Priezvisko</label>
                            <input type="text" @bind="editUserLastName" class="cd-input" />
                        </div>
                    </div>
                    <div class="cd-form-row">
                        <div class="cd-field">
                            <label>E-mail</label>
                            <input type="email" @bind="editUserEmail" class="cd-input" />
                        </div>
                        <div class="cd-field">
                            <label>Rola</label>
                            <select @bind="editUserRole" class="cd-input">
                                <option value="Owner">Majiteľ</option>
                                <option value="Service">Servis</option>
                                <option value="Admin">Administrátor</option>
                            </select>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(editUserMessage))
                    {
                        <div class="cd-alert @(editUserSuccess ? "cd-alert-ok" : "cd-alert-err")">
                            @editUserMessage
                        </div>
                    }
                    <div class="cd-form-actions">
                        <button type="button" @onclick="() => showEditUserModal = false" class="cd-btn cd-btn-ghost">Zrušiť</button>
                        <button type="button" @onclick="AdminSaveUser" class="cd-btn cd-btn-primary" disabled="@isLoading">Uložiť</button>
                    </div>
                </div>
            </div>
        </div>
    }
}
</div>

<style>
    /* ========================================
       CARD DASHBOARD - COMPLETE REDESIGN
       ======================================== */
    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
        --cd-primary: #2563eb;
        --cd-primary-dark: #1d4ed8;
        --cd-secondary: #0ea5e9;
        --cd-blue: #3b82f6;
        --cd-purple: #8b5cf6;
        --cd-green: #22c55e;
        --cd-orange: #f97316;
        --cd-red: #ef4444;
        --cd-dark: #0f172a;
        --cd-gray: #64748b;
        --cd-gray-light: #94a3b8;
        --cd-light: #f1f5f9;
        --cd-lighter: #f8fafc;
        --cd-white: #ffffff;
        --cd-border: #e2e8f0;
        --cd-radius: 20px;
        --cd-radius-sm: 14px;
        --cd-radius-xs: 10px;
        --cd-shadow: 0 4px 24px rgba(15, 23, 42, 0.06);
        --cd-shadow-lg: 0 12px 40px rgba(15, 23, 42, 0.1);
        --cd-shadow-card: 0 2px 12px rgba(15, 23, 42, 0.04), 0 0 0 1px rgba(15, 23, 42, 0.03);
    }

    .cd-dashboard {
        min-height: 100vh;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f4f6f8;
        color: var(--cd-dark);
    }

    /* NAVBAR */
    .cd-navbar {
        background: rgba(255,255,255,0.85);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--cd-border);
        padding: 12px 0;
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .cd-nav-inner {
        max-width: 1440px;
        margin: 0 auto;
        padding: 0 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .cd-brand {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 18px;
        font-weight: 800;
        color: var(--cd-dark);
    }

    .cd-brand-icon {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        background: var(--cd-primary);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .cd-nav-right {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .cd-user-pill {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 6px 16px 6px 6px;
        background: var(--cd-light);
        border-radius: 999px;
    }

    .cd-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: var(--cd-primary);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 14px;
    }

    .cd-user-text {
        display: flex;
        flex-direction: column;
    }

    .cd-user-name {
        font-size: 13px;
        font-weight: 700;
        color: var(--cd-dark);
        line-height: 1.2;
    }

    .cd-user-role {
        font-size: 11px;
        color: var(--cd-gray);
    }

    .cd-btn-logout {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        background: transparent;
        border: 1.5px solid var(--cd-border);
        border-radius: 999px;
        color: var(--cd-gray);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .cd-btn-logout:hover {
        background: var(--cd-red);
        border-color: var(--cd-red);
        color: white;
    }

    /* MAIN */
    .cd-main {
        padding: 32px 0 64px;
    }

    .cd-container {
        max-width: 1440px;
        margin: 0 auto;
        padding: 0 32px;
        display: flex;
        flex-direction: column;
        gap: 28px;
    }

    /* HERO CARD */
    .cd-hero-card {
        background: #1e3a5f;
        border-radius: var(--cd-radius);
        padding: 36px 40px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: white;
        box-shadow: 0 4px 16px rgba(15, 23, 42, 0.12);
    }

    .cd-hero-card.admin-hero {
        background: #1a1a2e;
    }

    .cd-hero-card h1 {
        font-size: 32px;
        font-weight: 900;
        letter-spacing: -0.02em;
        margin-bottom: 6px;
    }

    .cd-hero-card p {
        font-size: 15px;
        opacity: 0.85;
    }

    /* STAT CARDS */
    .cd-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
    }

    .cd-stat-card {
        background: var(--cd-white);
        border-radius: var(--cd-radius-sm);
        padding: 22px 24px;
        display: flex;
        align-items: center;
        gap: 16px;
        box-shadow: var(--cd-shadow-card);
        transition: all 0.25s ease;
        border: 1px solid transparent;
    }

    .cd-stat-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--cd-shadow-lg);
        border-color: var(--cd-border);
    }

    .cd-stat-icon {
        width: 52px;
        height: 52px;
        border-radius: var(--cd-radius-xs);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        flex-shrink: 0;
    }

    .cd-stat-icon.blue { background: #dbeafe; color: #2563eb; }
    .cd-stat-icon.green { background: #dcfce7; color: #16a34a; }
    .cd-stat-icon.purple { background: #ede9fe; color: #7c3aed; }
    .cd-stat-icon.orange { background: #ffedd5; color: #ea580c; }

    .cd-stat-body {
        display: flex;
        flex-direction: column;
    }

    .cd-stat-value {
        font-size: 28px;
        font-weight: 800;
        color: var(--cd-dark);
        line-height: 1;
    }

    .cd-stat-label {
        font-size: 12px;
        color: var(--cd-gray);
        font-weight: 500;
        margin-top: 4px;
    }

    /* SECTION CARD */
    .cd-section-card {
        background: var(--cd-white);
        border-radius: var(--cd-radius);
        padding: 28px 32px;
        box-shadow: var(--cd-shadow-card);
        border: 1px solid rgba(226, 232, 240, 0.6);
    }

    .cd-section-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .cd-section-head h2 {
        font-size: 20px;
        font-weight: 800;
        color: var(--cd-dark);
    }

    .cd-head-actions {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .cd-badge {
        padding: 5px 14px;
        background: var(--cd-light);
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        color: var(--cd-gray);
    }

    .cd-badge-outline {
        padding: 5px 14px;
        border: 1.5px solid var(--cd-border);
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        color: var(--cd-gray);
    }

    /* TWO COLUMN */
    .cd-two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        align-items: start;
    }

    /* BUTTONS */
    .cd-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 22px;
        border-radius: var(--cd-radius-xs);
        border: none;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        font-family: inherit;
    }

    .cd-btn-primary {
        background: var(--cd-primary);
        color: white;
    }

    .cd-btn-primary:hover:not(:disabled) {
        background: var(--cd-primary-dark);
    }

    .cd-btn-primary:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .cd-btn-accent {
        background: white;
        color: var(--cd-primary);
        font-weight: 700;
    }

    .cd-btn-accent:hover {
        background: #f0f4ff;
    }

    .cd-btn-ghost {
        background: var(--cd-light);
        color: var(--cd-gray);
        padding: 10px 22px;
    }

    .cd-btn-ghost:hover {
        background: var(--cd-border);
        color: var(--cd-dark);
    }

    .cd-btn-sm {
        padding: 7px 16px;
        font-size: 13px;
    }

    /* VEHICLE CARDS */
    .cd-vehicle-cards {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
    }

    .cd-vehicle-card {
        background: var(--cd-lighter);
        border: 2px solid var(--cd-border);
        border-radius: var(--cd-radius-sm);
        padding: 20px;
        cursor: pointer;
        transition: all 0.25s ease;
    }

    .cd-vehicle-card:hover {
        border-color: var(--cd-primary);
        transform: translateY(-3px);
        box-shadow: var(--cd-shadow);
    }

    .cd-vehicle-card.active {
        border-color: var(--cd-primary);
        background: #eff6ff;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }

    .cd-vc-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 14px;
    }

    .cd-vc-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: var(--cd-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    .cd-vc-status {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        font-weight: 600;
        color: var(--cd-gray);
    }

    .cd-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .cd-dot.success { background: var(--cd-green); box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.2); }
    .cd-dot.warning { background: var(--cd-orange); box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.2); }
    .cd-dot.danger { background: var(--cd-red); box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.2); }

    .cd-vehicle-card h3 {
        font-size: 17px;
        font-weight: 700;
        color: var(--cd-dark);
        margin-bottom: 10px;
    }

    .cd-vc-tags {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-bottom: 8px;
    }

    .cd-tag {
        padding: 4px 12px;
        background: var(--cd-white);
        border: 1px solid var(--cd-border);
        border-radius: 8px;
        font-size: 12px;
        font-weight: 600;
        color: var(--cd-dark);
    }

    .cd-tag-sm {
        padding: 2px 8px;
        background: var(--cd-light);
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        color: var(--cd-gray);
    }

    .cd-vc-vin {
        font-size: 11px;
        color: var(--cd-gray-light);
        margin: 0;
    }

    .cd-vc-footer {
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid var(--cd-border);
        font-size: 12px;
        color: var(--cd-gray);
        font-weight: 500;
    }

    .cd-transfer-code-box {
        margin-top: 10px;
        padding: 10px 14px;
        background: #fffbeb;
        border: 1.5px dashed #f59e0b;
        border-radius: 10px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        align-items: center;
    }

    .cd-transfer-code {
        font-size: 20px;
        font-weight: 900;
        letter-spacing: 4px;
        color: #b45309;
        font-family: 'Courier New', monospace;
    }

    /* VEHICLE LIST (compact for service) */
    .cd-vehicle-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .cd-vehicle-card-compact {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 18px;
        background: var(--cd-lighter);
        border: 2px solid var(--cd-border);
        border-radius: var(--cd-radius-xs);
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .cd-vehicle-card-compact:hover {
        border-color: var(--cd-primary);
        background: #f8faff;
    }

    .cd-vehicle-card-compact.active {
        border-color: var(--cd-primary);
        background: #eff6ff;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }

    .cd-vcc-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: var(--cd-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        flex-shrink: 0;
    }

    .cd-vcc-info {
        flex: 1;
        min-width: 0;
    }

