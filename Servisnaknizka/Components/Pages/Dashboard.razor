@page "/dashboard"
@layout EmptyLayout
@rendermode InteractiveServer
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject ApplicationDbContext DbContext

<PageTitle>Dashboard - Servisná knižka</PageTitle>

<div class="modern-dashboard">
@if (!isInitialized)
{
    <div class="loading-screen">
        <div class="loading-spinner"></div>
        <p>Načítavam...</p>
    </div>
}
else if (!isAuthenticated)
{
    <div class="loading-screen">
        <p>Presmerováva sa na prihlasovaciu stránku...</p>
    </div>
}
else
{
    <div class="dashboard-container">
        <!-- MODERN SIDEBAR -->
        <aside class="modern-sidebar">
            <div class="sidebar-header">
                <div class="logo-wrapper">
                    <div class="logo-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M19 9L12 3L5 9V19C5 19.5304 5.21071 20.0391 5.58579 20.4142C5.96086 20.7893 6.46957 21 7 21H17C17.5304 21 18.0391 20.7893 18.4142 20.4142C18.7893 20.0391 19 19.5304 19 19V9Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <div class="logo-text">
                        <h2>ServisKnižka</h2>
                        <p>Digitálna evidencia</p>
                    </div>
                </div>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section">
                    <span class="nav-section-title">MENU</span>
                    <ul class="nav-items">
                        <li>
                            <a href="/dashboard" class="nav-link active">
                                <span class="nav-icon">📊</span>
                                <span>Dashboard</span>
                            </a>
                        </li>
                        <li>
                            <a href="/service-records" class="nav-link">
                                <span class="nav-icon">🔧</span>
                                <span>Servisné záznamy</span>
                            </a>
                        </li>
                        <li>
                            <a href="/profile" class="nav-link">
                                <span class="nav-icon">👤</span>
                                <span>Môj profil</span>
                            </a>
                        </li>
                    </ul>
                </div>

                @if (userRole == "admin" || userRole == "service")
                {
                    <div class="nav-section">
                        <span class="nav-section-title">SPRÁVA</span>
                        <ul class="nav-items">
                            <li>
                                <a href="/vehicles/manage" class="nav-link">
                                    <span class="nav-icon">🚗</span>
                                    <span>Vozidlá</span>
                                </a>
                            </li>
                            <li>
                                <a href="/permissions" class="nav-link">
                                    <span class="nav-icon">🔐</span>
                                    <span>Oprávnenia</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                }
            </nav>

            <div class="sidebar-footer">
                <div class="user-info">
                    <div class="user-avatar">
                        @userEmail.Substring(0, 1).ToUpper()
                    </div>
                    <div class="user-details">
                        <strong>@userEmail</strong>
                        <span>@GetRoleDisplayName()</span>
                    </div>
                </div>
                <button class="btn-logout" @onclick="Logout">
                    <span>🚪</span> Odhlásiť
                </button>
            </div>
        </aside>

        <!-- MODERN MAIN CONTENT -->
        <main class="main-content">
            <!-- TOP BAR -->
            <header class="top-bar">
                <div class="top-bar-left">
                    <h1>Prehľad vozidiel</h1>
                    <p>Kompletná evidencia servisných záznamov</p>
                </div>
                <div class="top-bar-right">
                    <span class="time-badge">
                        🕒 @DateTime.Now.ToString("HH:mm")
                    </span>
                    <button class="btn-secondary" @onclick="ExportAllRecords">
                        📥 Export
                    </button>
                    @if (userRole == "service" || userRole == "admin")
                    {
                        <button class="btn-primary" @onclick="() => showNewRecordForm = true">
                            ➕ Nový záznam
                        </button>
                    }
                </div>
            </header>

            <!-- CONTENT GRID -->
            <div class="content-layout">
                <!-- LEFT: VEHICLES -->
                <section class="card vehicle-card">
                    <div class="card-header">
                        <div>
                            <h3>@(userRole == "owner" ? "Moje vozidlá" : "Vozidlá v evidencii")</h3>
                            <p class="card-subtitle">
                                @if (vehicles != null && vehicles.Any())
                                {
                                    <span class="badge-count">@vehicles.Count()</span>
                                    @(" vozidiel v systéme")
                                }
                                else
                                {
                                    @("Žiadne vozidlá")
                                }
                            </p>
                        </div>
                        @if (userRole == "owner" || userRole == "admin")
                        {
                            <button class="btn-add" @onclick="ShowAddVehicleModal">
                                ➕ Pridať
                            </button>
                        }
                    </div>

                    <div class="vehicle-grid">
                        @if (vehicles != null && vehicles.Any())
                        {
                            @foreach (var vehicle in vehicles)
                            {
                                <div class="vehicle-card-item @(selectedVehicleId == vehicle.Id ? "selected" : "")" 
                                     @onclick="() => SelectVehicle(vehicle.Id)">
                                    <div class="vehicle-icon">🚗</div>
                                    <div class="vehicle-info">
                                        <h4>@vehicle.Brand @vehicle.Model</h4>
                                        <p class="vehicle-details">
                                            <span class="detail-badge">@vehicle.Year</span>
                                            <span class="detail-badge">@vehicle.LicensePlate</span>
                                        </p>
                                        <p class="vehicle-vin">VIN: @vehicle.VIN.Substring(Math.Max(0, vehicle.VIN.Length - 8))</p>
                                    </div>
                                    <div class="vehicle-status">
                                        <span class="status-dot @GetStatusClass(vehicle)"></span>
                                        <span class="status-text">@GetVehicleServiceStatus(vehicle)</span>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state">
                                <div class="empty-icon">🚗</div>
                                <h4>Žiadne vozidlá</h4>
                                <p>Začnite pridaním vášho prvého vozidla</p>
                                @if (userRole == "owner" || userRole == "admin")
                                {
                                    <button class="btn-primary" @onclick="ShowAddVehicleModal">
                                        ➕ Pridať vozidlo
                                    </button>
                                }
                            </div>
                        }
                    </div>

                    @if (selectedVehicle != null)
                    {
                        <div class="divider"></div>

                        <div class="service-history">
                            <div class="section-header">
                                <h3>📋 História údržby</h3>
                                <span class="record-count">
                                    @if (serviceRecords != null && serviceRecords.Any())
                                    {
                                        @($"{serviceRecords.Count()} záznamov")
                                    }
                                </span>
                            </div>

                            <div class="table-container">
                                <table class="modern-table">
                                    <thead>
                                        <tr>
                                            <th>Dátum</th>
                                            <th>Popis úkonu</th>
                                            <th>Kilometre</th>
                                            <th>Typ</th>
                                            <th>Cena</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (serviceRecords != null && serviceRecords.Any())
                                        {
                                            @foreach (var record in serviceRecords.OrderByDescending(r => r.ServiceDate).Take(10))
                                            {
                                                <tr class="table-row">
                                                    <td>
                                                        <span class="date-badge">@record.ServiceDate.ToString("dd.MM.yyyy")</span>
                                                    </td>
                                                    <td>@record.Description</td>
                                                    <td>
                                                        <span class="km-badge">@record.Mileage.ToString("N0") km</span>
                                                    </td>
                                                    <td>
                                                        <span class="type-badge">@(record.ServiceType ?? "—")</span>
                                                    </td>
                                                    <td>
                                                        <strong>@(record.Cost.HasValue ? $"{record.Cost:N2} €" : "—")</strong>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="5" class="empty-row">
                                                    <div class="empty-table">
                                                        <span class="empty-icon">📝</span>
                                                        <p>Žiadne servisné záznamy</p>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </section>

                <!-- RIGHT: FORM OR INFO -->
                @if ((userRole == "service" || userRole == "admin") && selectedVehicle != null)
                {
                    <section class="card form-card">
                        <div class="card-header">
                            <div>
                                <h3>➕ Nový záznam</h3>
                                <p class="card-subtitle">
                                    @selectedVehicle.Brand @selectedVehicle.Model
                                    <span class="license-badge">@selectedVehicle.LicensePlate</span>
                                </p>
                            </div>
                        </div>

                        <EditForm Model="newServiceRecord" OnValidSubmit="SaveServiceRecord" class="modern-form">
                            <DataAnnotationsValidator />

                            <div class="form-row">
                                <div class="form-group">
                                    <label>📅 Dátum</label>
                                    <InputDate @bind-Value="newServiceRecord.ServiceDate" class="form-input" />
                                    <ValidationMessage For="@(() => newServiceRecord.ServiceDate)" class="validation-error" />
                                </div>
                                <div class="form-group">
                                    <label>🛣️ Kilometre</label>
                                    <InputNumber @bind-Value="newServiceRecord.Mileage" class="form-input" placeholder="185200" />
                                    <ValidationMessage For="@(() => newServiceRecord.Mileage)" class="validation-error" />
                                </div>
                            </div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label>🔧 Typ úkonu</label>
                                    <InputSelect @bind-Value="newServiceRecord.ServiceType" class="form-select">
                                        <option value="">Vyber typ...</option>
                                        <option value="Pravidelná prehliadka">Pravidelná prehliadka</option>
                                        <option value="Výmena oleja">Výmena oleja</option>
                                        <option value="Brzdy">Brzdy</option>
                                        <option value="Pneumatiky">Pneumatiky</option>
                                        <option value="Motor / mechanické opravy">Motor / mechanické</option>
                                        <option value="Elektronika / diagnostika">Elektronika</option>
                                        <option value="STK / EK">STK / EK</option>
                                        <option value="Iné">Iné</option>
                                    </InputSelect>
                                </div>
                                <div class="form-group">
                                    <label>💰 Cena (€)</label>
                                    <InputNumber @bind-Value="newServiceRecord.Cost" class="form-input" placeholder="150.00" />
                                </div>
                            </div>

                            <div class="form-group">
                                <label>📝 Popis úkonu *</label>
                                <InputTextArea @bind-Value="newServiceRecord.Description" 
                                               class="form-textarea"
                                               placeholder="Stručne popíšte vykonané práce..." />
                                <ValidationMessage For="@(() => newServiceRecord.Description)" class="validation-error" />
                            </div>

                            <div class="form-group">
                                <label>🔩 Použité diely</label>
                                <InputText @bind-Value="newServiceRecord.PartsUsed" 
                                           class="form-input"
                                           placeholder="Olejový filter, brzdové platničky..." />
                            </div>

                            <div class="form-group">
                                <label>💬 Poznámka</label>
                                <InputTextArea @bind-Value="newServiceRecord.Notes" 
                                               class="form-textarea"
                                               placeholder="Odporúčania, upozornenia..." />
                            </div>

                            @if (!string.IsNullOrEmpty(formMessage))
                            {
                                <div class="alert @(formSuccess ? "alert-success" : "alert-error")">
                                    <span class="alert-icon">@(formSuccess ? "✓" : "⚠")</span>
                                    @formMessage
                                </div>
                            }

                            <div class="form-actions">
                                <button type="button" class="btn-secondary" @onclick="ClearForm">
                                    Zrušiť
                                </button>
                                <button type="submit" class="btn-primary" disabled="@isLoading">
                                    @if (isLoading)
                                    {
                                        <span class="spinner-sm"></span>
                                    }
                                    else
                                    {
                                        <span>💾 Uložiť</span>
                                    }
                                </button>
                            </div>
                        </EditForm>
                    </section>
                }
                else if (selectedVehicle == null && vehicles != null && vehicles.Any())
                {
                    <section class="card info-card">
                        <div class="info-content">
                            <div class="info-icon">👈</div>
                            <h3>Vyberte vozidlo</h3>
                            <p>Kliknite na vozidlo v zozname pre zobrazenie detailov a servisnej histórie</p>
                        </div>
                    </section>
                }
            </div>
        </main>
    </div>
}
</div>

<style>
    /* MODERN DASHBOARD STYLES */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        --primary: #6366f1;
        --primary-dark: #4f46e5;
        --secondary: #8b5cf6;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --dark: #1e293b;
        --dark-light: #334155;
        --gray: #64748b;
        --gray-light: #e2e8f0;
        --bg: #f8fafc;
        --white: #ffffff;
        --shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.05);
        --radius: 16px;
        --radius-sm: 12px;
    }

    .modern-dashboard {
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .dashboard-container {
        display: grid;
        grid-template-columns: 280px 1fr;
        min-height: 100vh;
    }

    /* MODERN SIDEBAR */
    .modern-sidebar {
        background: var(--white);
        box-shadow: var(--shadow);
        display: flex;
        flex-direction: column;
        padding: 24px;
        gap: 24px;
    }

    .sidebar-header {
        padding-bottom: 24px;
        border-bottom: 2px solid var(--gray-light);
    }

    .logo-wrapper {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .logo-icon {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

    .logo-text h2 {
        font-size: 18px;
        font-weight: 700;
        color: var(--dark);
        margin: 0;
    }

    .logo-text p {
        font-size: 12px;
        color: var(--gray);
        margin: 0;
    }

    .sidebar-nav {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .nav-section-title {
        font-size: 11px;
        font-weight: 700;
        color: var(--gray);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 8px;
        display: block;
    }

    .nav-items {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .nav-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        border-radius: var(--radius-sm);
        color: var(--dark-light);
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.2s ease;
    }

    .nav-link:hover {
        background: var(--gray-light);
        transform: translateX(4px);
    }

    .nav-link.active {
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: white;
        box-shadow: var(--shadow-sm);
    }

    .nav-icon {
        font-size: 20px;
    }

    .sidebar-footer {
        border-top: 2px solid var(--gray-light);
        padding-top: 20px;
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
    }

    .user-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 16px;
    }

    .user-details {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .user-details strong {
        font-size: 13px;
        color: var(--dark);
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .user-details span {
        font-size: 11px;
        color: var(--gray);
    }

    .btn-logout {
        width: 100%;
        padding: 10px;
        background: var(--gray-light);
        border: none;
        border-radius: var(--radius-sm);
        color: var(--dark);
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .btn-logout:hover {
        background: var(--danger);
        color: white;
        transform: translateY(-2px);
        box-shadow: var(--shadow-sm);
    }

    /* MAIN CONTENT */
    .main-content {
        background: var(--bg);
        padding: 32px;
        overflow-y: auto;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
        padding: 24px;
        background: white;
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
    }

    .top-bar-left h1 {
        font-size: 28px;
        font-weight: 700;
        color: var(--dark);
        margin: 0 0 4px 0;
    }

    .top-bar-left p {
        font-size: 14px;
        color: var(--gray);
        margin: 0;
    }

    .top-bar-right {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .time-badge {
        padding: 8px 16px;
        background: var(--gray-light);
        border-radius: 999px;
        font-size: 13px;
        color: var(--dark);
        font-weight: 600;
    }

    /* BUTTONS */
    .btn-primary, .btn-secondary, .btn-add {
        padding: 10px 20px;
        border-radius: var(--radius-sm);
        border: none;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: white;
        box-shadow: var(--shadow-sm);
    }

    .btn-primary:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(99, 102, 241, 0.3);
    }

    .btn-primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .btn-secondary {
        background: white;
        color: var(--dark);
        border: 2px solid var(--gray-light);
    }

    .btn-secondary:hover {
        border-color: var(--primary);
        color: var(--primary);
        transform: translateY(-2px);
    }

    .btn-add {
        background: var(--success);
        color: white;
    }

    .btn-add:hover {
        background: #059669;
        transform: translateY(-2px);
    }

    /* CONTENT LAYOUT */
    .content-layout {
        display: grid;
        grid-template-columns: 1.8fr 1.2fr;
        gap: 24px;
        align-items: start;
    }

    /* CARD */
    .card {
        background: white;
        border-radius: var(--radius);
        padding: 24px;
        box-shadow: var(--shadow-sm);
        transition: all 0.3s ease;
    }

    .card:hover {
        box-shadow: var(--shadow);
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: start;
        margin-bottom: 24px;
    }

    .card-header h3 {
        font-size: 20px;
        font-weight: 700;
        color: var(--dark);
        margin: 0 0 4px 0;
    }

    .card-subtitle {
        font-size: 13px;
        color: var(--gray);
        margin: 0;
    }

    .badge-count {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 24px;
        height: 24px;
        padding: 0 8px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: white;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
    }

    /* VEHICLE GRID */
    .vehicle-grid {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .vehicle-card-item {
        display: grid;
        grid-template-columns: 60px 1fr auto;
        gap: 16px;
        padding: 16px;
        background: linear-gradient(135deg, #f8fafc, #ffffff);
        border: 2px solid var(--gray-light);
        border-radius: var(--radius-sm);
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .vehicle-card-item:hover {
        border-color: var(--primary);
        transform: translateY(-2px);
        box-shadow: var(--shadow-sm);
    }

    .vehicle-card-item.selected {
        border-color: var(--primary);
        background: linear-gradient(135deg, #eef2ff, #f5f3ff);
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
    }

    .vehicle-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
    }

    .vehicle-info h4 {
        font-size: 16px;
        font-weight: 700;
        color: var(--dark);
        margin: 0 0 8px 0;
    }

    .vehicle-details {
        display: flex;
        gap: 8px;
        margin-bottom: 4px;
    }

    .detail-badge {
        padding: 4px 12px;
        background: var(--gray-light);
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        color: var(--dark);
    }

    .vehicle-vin {
        font-size: 11px;
        color: var(--gray);
        font-family: 'Courier New', monospace;
        margin: 0;
    }

    .vehicle-status {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 4px;
        justify-content: center;
    }

    .status-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        margin-bottom: 4px;
    }

    .status-dot.success {
        background: var(--success);
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.2);
    }

    .status-dot.warning {
        background: var(--warning);
        box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.2);
    }

    .status-dot.danger {
        background: var(--danger);
        box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.2);
    }

    .status-text {
