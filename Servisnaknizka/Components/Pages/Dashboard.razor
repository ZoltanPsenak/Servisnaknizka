    // ========== VEHICLE TRANSFER ==========

    private async Task GenerateTransferCode(Vehicle vehicle)
    {
        try
        {
            var dbVehicle = await DbContext.Vehicles.FindAsync(vehicle.Id);
            if (dbVehicle == null || dbVehicle.OwnerId != currentUserId) return;

            // Generate random 8-char alphanumeric code
            var chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
            var code = new char[8];
            using var rng = System.Security.Cryptography.RandomNumberGenerator.Create();
            var bytes = new byte[8];
            rng.GetBytes(bytes);
            for (int i = 0; i < 8; i++)
                code[i] = chars[bytes[i] % chars.Length];

            dbVehicle.TransferCode = new string(code);
            dbVehicle.TransferCodeExpiry = DateTime.UtcNow.AddHours(24);
            await DbContext.SaveChangesAsync();

            await LoadDataFromDatabase();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error generating transfer code: {ex.Message}");
        }
        StateHasChanged();
    }

    private async Task ClaimVehicleByCode()
    {
        claimMessage = string.Empty;
        var code = claimTransferCode?.Trim().ToUpperInvariant();

        if (string.IsNullOrWhiteSpace(code) || code.Length != 8)
        {
            claimMessage = "Zadajte platný 8-miestny prenosový kód.";
            claimSuccess = false;
            StateHasChanged();
            return;
        }

        isLoading = true;
        StateHasChanged();

        try
        {
            var vehicle = await DbContext.Vehicles
                .Include(v => v.ServicePermissions)
                .FirstOrDefaultAsync(v => v.TransferCode == code && v.IsActive);

            if (vehicle == null)
            {
                claimMessage = "Vozidlo s týmto kódom nebolo nájdené.";
                claimSuccess = false;
                isLoading = false;
                StateHasChanged();
                return;
            }

            if (vehicle.TransferCodeExpiry == null || vehicle.TransferCodeExpiry < DateTime.UtcNow)
            {
                claimMessage = "Platnosť prenosového kódu vypršala. Požiadajte majiteľa o nový kód.";
                claimSuccess = false;
                isLoading = false;
                StateHasChanged();
                return;
            }

            if (vehicle.OwnerId == currentUserId)
            {
                claimMessage = "Toto vozidlo už vlastníte.";
                claimSuccess = false;
                isLoading = false;
                StateHasChanged();
                return;
            }

            // Transfer the vehicle to the new owner
            vehicle.OwnerId = currentUserId;
            vehicle.TransferCode = null;
            vehicle.TransferCodeExpiry = null;

            // Deactivate existing permissions (new owner will grant new ones)
            foreach (var perm in vehicle.ServicePermissions)
            {
                perm.IsActive = false;
            }

            await DbContext.SaveChangesAsync();

            claimMessage = $"Vozidlo {vehicle.Brand} {vehicle.Model} ({vehicle.LicensePlate}) bolo úspešne prenesené na váš účet!";
            claimSuccess = true;
            claimTransferCode = string.Empty;
            showClaimVehicleForm = false;

            await LoadDataFromDatabase();
        }
        catch (Exception ex)
        {
            claimMessage = $"Chyba: {ex.Message}";
            claimSuccess = false;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    // ========== NOTIFICATION METHODS ==========

    private async Task LoadNotifications()
    {
        notifications = await DbContext.Notifications
            .Where(n => n.UserId == currentUserId)
            .OrderByDescending(n => n.CreatedAt)
            .Take(50)
            .ToListAsync();
        unreadCount = notifications.Count(n => !n.IsRead);
    }

    private async Task ToggleNotifications()
    {
        showNotifPanel = !showNotifPanel;
        if (showNotifPanel)
        {
            await LoadNotifications();
        }
    }

    private async Task MarkAsRead(int notifId)
    {
        var notif = notifications.FirstOrDefault(n => n.Id == notifId);
        if (notif != null && !notif.IsRead)
        {
            var dbNotif = await DbContext.Notifications.FindAsync(notifId);
            if (dbNotif != null)
            {
                dbNotif.IsRead = true;
                await DbContext.SaveChangesAsync();
                notif.IsRead = true;
                unreadCount = notifications.Count(n => !n.IsRead);
            }
        }
    }

    private async Task MarkAllAsRead()
    {
        var unread = await DbContext.Notifications
            .Where(n => n.UserId == currentUserId && !n.IsRead)
            .ToListAsync();
        foreach (var n in unread) n.IsRead = true;
        await DbContext.SaveChangesAsync();
        foreach (var n in notifications) n.IsRead = true;
        unreadCount = 0;
    }

    private void OpenReminderSettings(Vehicle vehicle)
    {
        reminderVehicleId = vehicle.Id;
        reminderVehicleName = $"{vehicle.Brand} {vehicle.Model} ({vehicle.LicensePlate})";
        reminderInterval = vehicle.ServiceIntervalMonths;
        reminderStkExpiry = vehicle.StkExpiry;
        reminderEmissionExpiry = vehicle.EmissionExpiry;
        reminderInsuranceExpiry = vehicle.InsuranceExpiry;
        reminderMessage = string.Empty;
        showReminderModal = true;
    }

    private string GetExpiryHint(DateTime? expiry, string label)
    {
        if (!expiry.HasValue) return $"Dátum expirácie {label} nie je nastavený.";
        var days = (expiry.Value.Date - DateTime.Today).Days;
        if (days < 0) return $"⚠ Platnosť {label} vypršala pred {Math.Abs(days)} dňami!";
        if (days == 0) return $"⚠ Platnosť {label} vyprší dnes!";
        if (days <= 30) return $"Platnosť {label} vyprší o {days} dní. Budete upozornení.";
        return $"Platnosť {label} do {expiry.Value:dd.MM.yyyy} (zostáva {days} dní). Upozornenie 30 dní pred.";
    }

    private async Task SaveReminderSettings()
    {
        try
        {
            isLoading = true;
            reminderMessage = string.Empty;
            var vehicle = await DbContext.Vehicles.FindAsync(reminderVehicleId);
            if (vehicle == null || vehicle.OwnerId != currentUserId) return;

            vehicle.ServiceIntervalMonths = reminderInterval;
            vehicle.StkExpiry = reminderStkExpiry;
            vehicle.EmissionExpiry = reminderEmissionExpiry;
            vehicle.InsuranceExpiry = reminderInsuranceExpiry;

            // Prepočítať NextServiceDate
            if (reminderInterval > 0)
            {
                var lastService = await DbContext.ServiceRecords
                    .Where(sr => sr.VehicleId == vehicle.Id)
                    .OrderByDescending(sr => sr.ServiceDate)
                    .FirstOrDefaultAsync();

                vehicle.NextServiceDate = lastService != null
                    ? lastService.ServiceDate.AddMonths(reminderInterval)
                    : DateTime.UtcNow.AddMonths(reminderInterval);
            }
            else
            {
                vehicle.NextServiceDate = null;
            }

            await DbContext.SaveChangesAsync();

            // Aktualizovať lokálny stav
            var localVehicle = vehicles?.FirstOrDefault(v => v.Id == reminderVehicleId);
            if (localVehicle != null)
            {
                localVehicle.ServiceIntervalMonths = reminderInterval;
                localVehicle.NextServiceDate = vehicle.NextServiceDate;
                localVehicle.StkExpiry = reminderStkExpiry;
                localVehicle.EmissionExpiry = reminderEmissionExpiry;
                localVehicle.InsuranceExpiry = reminderInsuranceExpiry;
            }

            reminderMessage = "Nastavenia pripomienok boli úspešne uložené.";
            reminderSuccess = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Reminder save error: {ex.Message}");
            reminderMessage = "Chyba pri ukladaní nastavení.";
            reminderSuccess = false;
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string FormatNotifTime(DateTime created)
    {
        var diff = DateTime.UtcNow - created;
        if (diff.TotalMinutes < 60) return $"pred {(int)diff.TotalMinutes} min";
        if (diff.TotalHours < 24) return $"pred {(int)diff.TotalHours} h";
        if (diff.TotalDays < 7) return $"pred {(int)diff.TotalDays} d";
        return created.ToString("dd.MM.yyyy");
    }

