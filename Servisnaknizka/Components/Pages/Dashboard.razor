@page "/dashboard"
@layout EmptyLayout
@rendermode InteractiveServer
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject ApplicationDbContext DbContext

<PageTitle>Dashboard - Servisná knižka</PageTitle>

<div class="modern-dashboard">
@if (!isInitialized)
{
    <div class="loading-screen">
        <div class="loading-spinner"></div>
        <p>Načítavam...</p>
    </div>
}
else if (!isAuthenticated)
{
    <div class="loading-screen">
        <p>Presmerováva sa na prihlasovaciu stránku...</p>
    </div>
}
else
{
    <!-- NAVIGATION BAR -->
    <nav class="dashboard-navbar">
        <div class="nav-container">
            <div class="nav-brand">
                <span class="brand-text">Servisná Knižka</span>
            </div>
            <div class="nav-right">
                <div class="user-menu">
                    <div class="user-avatar">@GetUserInitials()</div>
                    <div class="user-info-menu">
                        <div class="user-name">@GetUserName()</div>
                        <div class="user-role">@GetRoleDisplayName()</div>
                    </div>
                </div>
                <button @onclick="Logout" class="btn-logout-nav">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    Odhlásiť sa
                </button>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <div class="dashboard-content">
        <div class="content-container">
            
            @if (userRole == "owner")
            {
                <!-- MAJITEĽ VOZIDLA -->
                <div class="welcome-section">
                    <h1>Vitajte späť! 👋</h1>
                    <p>Prehľad vašich vozidiel a servisnej histórie</p>
                </div>

                <div class="stats-grid">
                    <div class="stat-card blue">
                        <div class="stat-icon">🚗</div>
                        <div class="stat-content">
                            <div class="stat-number">@(vehicles?.Count ?? 0)</div>
                            <div class="stat-label">Vozidlá</div>
                        </div>
                    </div>
                    <div class="stat-card green">
                        <div class="stat-icon">📋</div>
                        <div class="stat-content">
                            <div class="stat-number">@(serviceRecords?.Count ?? 0)</div>
                            <div class="stat-label">Servisných záznamov</div>
                        </div>
                    </div>
                    <div class="stat-card purple">
                        <div class="stat-icon">🔧</div>
                        <div class="stat-content">
                            <div class="stat-number">@GetRecentServices()</div>
                            <div class="stat-label">Posledný mesiac</div>
                        </div>
                    </div>
                    <div class="stat-card orange">
                        <div class="stat-icon">💰</div>
                        <div class="stat-content">
                            <div class="stat-number">@GetTotalCost() €</div>
                            <div class="stat-label">Celkové náklady</div>
                        </div>
                    </div>
                </div>

                <div class="content-grid">
                    <!-- VOZIDLÁ -->
                    <div class="dashboard-card">
                        <div class="card-header">
                            <div>
                                <h2>Moje vozidlá</h2>
                                <p class="card-subtitle">Kliknutím vyberte vozidlo</p>
                            </div>
                            <button @onclick="ShowAddVehicleModal" class="btn-add">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <line x1="12" y1="5" x2="12" y2="19"/>
                                    <line x1="5" y1="12" x2="19" y2="12"/>
                                </svg>
                                Pridať vozidlo
                            </button>
                        </div>
                        
                        @if (vehicles == null || !vehicles.Any())
                        {
                            <div class="empty-state">
                                <div class="empty-icon">🚗</div>
                                <h3>Žiadne vozidlá</h3>
                                <p>Pridajte svoje prvé vozidlo a začnite evidovať servisné záznamy</p>
                                <button @onclick="ShowAddVehicleModal" class="btn-primary">
                                    Pridať prvé vozidlo
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="vehicle-grid">
                                @foreach (var vehicle in vehicles)
                                {
                                    <div class="vehicle-card @(selectedVehicleId == vehicle.Id ? "selected" : "")" 
                                         @onclick="() => SelectVehicle(vehicle.Id)">
                                        <div class="vehicle-icon">🚙</div>
                                        <div class="vehicle-info">
                                            <h3>@vehicle.Brand @vehicle.Model</h3>
                                            <div class="vehicle-details">
                                                <span class="detail-badge">@vehicle.Year</span>
                                                <span class="detail-badge">@vehicle.LicensePlate</span>
                                            </div>
                                            <p class="vehicle-vin">VIN: @vehicle.VIN</p>
                                        </div>
                                        <div class="vehicle-status">
                                            <div class="status-dot @GetStatusClass(vehicle)"></div>
                                            <span class="status-text">@GetVehicleServiceStatus(vehicle)</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <!-- SERVISNÁ HISTÓRIA -->
                    <div class="dashboard-card">
                        <div class="card-header">
                            <div>
                                <h2>História servisov</h2>
                                <p class="card-subtitle">@(selectedVehicle?.Brand ?? "Vyberte") @(selectedVehicle?.Model ?? "vozidlo")</p>
                            </div>
                            @if (selectedVehicle != null)
                            {
                                <button @onclick="() => showNewRecordForm = !showNewRecordForm" class="btn-primary">
                                    @if (showNewRecordForm)
                                    {
                                        <span>Zrušiť</span>
                                    }
                                    else
                                    {
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <line x1="12" y1="5" x2="12" y2="19"/>
                                            <line x1="5" y1="12" x2="19" y2="12"/>
                                        </svg>
                                        <span>Nový záznam</span>
                                    }
                                </button>
                            }
                        </div>

                        @if (showNewRecordForm && selectedVehicle != null)
                        {
                            <div class="form-card">
                                <h3>Nový servisný záznam</h3>
                                <EditForm Model="newServiceRecord" OnValidSubmit="SaveServiceRecord" class="modern-form">
                                    <DataAnnotationsValidator />
                                    
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label>Dátum servisu *</label>
                                            <InputDate @bind-Value="newServiceRecord.ServiceDate" class="form-input" />
                                            <ValidationMessage For="@(() => newServiceRecord.ServiceDate)" class="validation-error" />
                                        </div>
                                        <div class="form-group">
                                            <label>Kilometrov *</label>
                                            <InputNumber @bind-Value="newServiceRecord.Mileage" class="form-input" placeholder="125000" />
                                            <ValidationMessage For="@(() => newServiceRecord.Mileage)" class="validation-error" />
                                        </div>
                                    </div>

                                    <div class="form-row">
                                        <div class="form-group">
                                            <label>Typ servisu *</label>
                                            <InputSelect @bind-Value="newServiceRecord.ServiceType" class="form-input">
                                                <option value="">-- Vyberte typ --</option>
                                                <option value="Pravidelný servis">Pravidelný servis</option>
                                                <option value="Oprava">Oprava</option>
                                                <option value="STK">STK</option>
                                                <option value="Emisná kontrola">Emisná kontrola</option>
                                                <option value="Výmena pneumatík">Výmena pneumatík</option>
                                                <option value="Diagnostika">Diagnostika</option>
                                                <option value="Iné">Iné</option>
                                            </InputSelect>
                                            <ValidationMessage For="@(() => newServiceRecord.ServiceType)" class="validation-error" />
                                        </div>
                                        <div class="form-group">
                                            <label>Cena (€)</label>
                                            <InputNumber @bind-Value="newServiceRecord.Cost" class="form-input" placeholder="150.00" />
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label>Popis prác *</label>
                                        <InputTextArea @bind-Value="newServiceRecord.Description" class="form-textarea" 
                                                      placeholder="Výmena oleja, olejového filtra..." rows="3" />
                                        <ValidationMessage For="@(() => newServiceRecord.Description)" class="validation-error" />
                                    </div>

                                    <div class="form-group">
                                        <label>Použité diely</label>
                                        <InputText @bind-Value="newServiceRecord.PartsUsed" class="form-input" 
                                                  placeholder="Olej 5W30, Olejový filter Mann..." />
                                    </div>

                                    <div class="form-group">
                                        <label>Poznámky</label>
                                        <InputTextArea @bind-Value="newServiceRecord.Notes" class="form-textarea" 
                                                      placeholder="Dodatočné poznámky..." rows="2" />
                                    </div>

                                    @if (!string.IsNullOrEmpty(formMessage))
                                    {
                                        <div class="alert @(formSuccess ? "alert-success" : "alert-error")">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                @if (formSuccess)
                                                {
                                                    <polyline points="20 6 9 17 4 12"/>
                                                }
                                                else
                                                {
                                                    <circle cx="12" cy="12" r="10"/>
                                                    <line x1="15" y1="9" x2="9" y2="15"/>
                                                    <line x1="9" y1="9" x2="15" y2="15"/>
                                                }
                                            </svg>
                                            <span>@formMessage</span>
                                        </div>
                                    }

                                    <div class="form-actions">
                                        <button type="button" @onclick="ClearForm" class="btn-secondary">Zrušiť</button>
                                        <button type="submit" class="btn-primary" disabled="@isLoading">
                                            @if (isLoading)
                                            {
                                                <span class="spinner-sm"></span>
                                                <span>Ukladám...</span>
                                            }
                                            else
                                            {
                                                <span>Uložiť záznam</span>
                                            }
                                        </button>
                                    </div>
                                </EditForm>
                            </div>
                        }

                        @if (selectedVehicle == null)
                        {
                            <div class="info-state">
                                <div class="info-icon">👈</div>
                                <h3>Vyberte vozidlo</h3>
                                <p>Vyberte vozidlo z ľavej strany pre zobrazenie histórie servisov</p>
                            </div>
                        }
                        else if (serviceRecords == null || !serviceRecords.Any())
                        {
                            <div class="empty-state">
                                <div class="empty-icon">📋</div>
                                <h3>Žiadne záznamy</h3>
                                <p>Pre toto vozidlo ešte nie sú evidované žiadne servisné záznamy</p>
                            </div>
                        }
                        else
                        {
                            <div class="records-list">
                                @foreach (var record in serviceRecords.OrderByDescending(r => r.ServiceDate))
                                {
                                    <div class="record-item">
                                        <div class="record-date">
                                            <div class="date-day">@record.ServiceDate.Day</div>
                                            <div class="date-month">@record.ServiceDate.ToString("MMM yyyy")</div>
                                        </div>
                                        <div class="record-content">
                                            <div class="record-header">
                                                <h4>@record.ServiceType</h4>
                                                <span class="record-km">@record.Mileage.ToString("N0") km</span>
                                            </div>
                                            <p class="record-description">@record.Description</p>
                                            @if (!string.IsNullOrEmpty(record.PartsUsed))
                                            {
                                                <p class="record-parts">🔧 @record.PartsUsed</p>
                                            }
                                            @if (record.Cost.HasValue)
                                            {
                                                <div class="record-cost">@record.Cost.Value.ToString("N2") €</div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
            else if (userRole == "service")
            {
                <!-- AUTOSERVIS -->
                <div class="welcome-section">
                    <h1>Autoservis Dashboard 🔧</h1>
                    <p>Správa klientskych vozidiel a servisných záznamov</p>
                </div>

                <div class="stats-grid">
                    <div class="stat-card blue">
                        <div class="stat-icon">🚗</div>
                        <div class="stat-content">
                            <div class="stat-number">@(vehicles?.Count ?? 0)</div>
                            <div class="stat-label">Prístupné vozidlá</div>
                        </div>
                    </div>
                    <div class="stat-card green">
                        <div class="stat-icon">✅</div>
                        <div class="stat-content">
                            <div class="stat-number">@GetRecentServices()</div>
                            <div class="stat-label">Dokončené tento mesiac</div>
                        </div>
                    </div>
                    <div class="stat-card purple">
                        <div class="stat-icon">📋</div>
                        <div class="stat-content">
                            <div class="stat-number">@(serviceRecords?.Count ?? 0)</div>
                            <div class="stat-label">Celkovo záznamov</div>
                        </div>
                    </div>
                    <div class="stat-card orange">
                        <div class="stat-icon">👥</div>
                        <div class="stat-content">
                            <div class="stat-number">@GetUniqueCustomers()</div>
                            <div class="stat-label">Klientov</div>
                        </div>
                    </div>
                </div>

                <div class="content-grid">
                    <div class="dashboard-card">
                        <div class="card-header">
                            <div>
                                <h2>Klientske vozidlá</h2>
                                <p class="card-subtitle">Vozidlá s udeleným prístupom</p>
                            </div>
                        </div>
                        
                        @if (vehicles == null || !vehicles.Any())
                        {
                            <div class="empty-state">
                                <div class="empty-icon">🚗</div>
                                <h3>Žiadne vozidlá</h3>
                                <p>Zatiaľ vám neboli udelené prístupové práva k žiadnym vozidlám</p>
                            </div>
                        }
                        else
                        {
                            <div class="vehicle-grid">
                                @foreach (var vehicle in vehicles)
                                {
                                    <div class="vehicle-card @(selectedVehicleId == vehicle.Id ? "selected" : "")" 
                                         @onclick="() => SelectVehicle(vehicle.Id)">
                                        <div class="vehicle-icon">🚙</div>
                                        <div class="vehicle-info">
                                            <h3>@vehicle.Brand @vehicle.Model</h3>
                                            <div class="vehicle-details">
                                                <span class="detail-badge">@vehicle.Year</span>
                                                <span class="detail-badge">@vehicle.LicensePlate</span>
                                            </div>
                                            <p class="vehicle-vin">Majiteľ: @vehicle.Owner.FullName</p>
                                        </div>
                                        <div class="vehicle-status">
                                            <span class="status-text">@vehicle.ServiceRecords.Count záznamov</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="dashboard-card">
                        <div class="card-header">
                            <div>
                                <h2>Pridať servisný záznam</h2>
                                <p class="card-subtitle">@(selectedVehicle?.Brand ?? "Vyberte") @(selectedVehicle?.Model ?? "vozidlo")</p>
                            </div>
                        </div>

                        @if (selectedVehicle == null)
                        {
                            <div class="info-state">
                                <div class="info-icon">👈</div>
                                <h3>Vyberte vozidlo</h3>
                                <p>Najprv vyberte vozidlo klienta z ľavej strany</p>
                            </div>
                        }
                        else
                        {
                            <div class="form-card">
                                <EditForm Model="newServiceRecord" OnValidSubmit="SaveServiceRecord" class="modern-form">
                                    <DataAnnotationsValidator />
                                    
                                    <div class="form-row">
                                        <div class="form-group">
                                            <label>Dátum servisu *</label>
                                            <InputDate @bind-Value="newServiceRecord.ServiceDate" class="form-input" />
                                            <ValidationMessage For="@(() => newServiceRecord.ServiceDate)" class="validation-error" />
                                        </div>
                                        <div class="form-group">
                                            <label>Stav kilometrov *</label>
                                            <InputNumber @bind-Value="newServiceRecord.Mileage" class="form-input" placeholder="125000" />
                                            <ValidationMessage For="@(() => newServiceRecord.Mileage)" class="validation-error" />
                                        </div>
                                    </div>

                                    <div class="form-row">
                                        <div class="form-group">
                                            <label>Typ servisu *</label>
                                            <InputSelect @bind-Value="newServiceRecord.ServiceType" class="form-input">
                                                <option value="">-- Vyberte typ --</option>
                                                <option value="Pravidelný servis">Pravidelný servis</option>
                                                <option value="Oprava">Oprava</option>
                                                <option value="STK">STK</option>
                                                <option value="Emisná kontrola">Emisná kontrola</option>
                                                <option value="Výmena pneumatík">Výmena pneumatík</option>
                                                <option value="Diagnostika">Diagnostika</option>
                                                <option value="Iné">Iné</option>
                                            </InputSelect>
                                            <ValidationMessage For="@(() => newServiceRecord.ServiceType)" class="validation-error" />
                                        </div>
                                        <div class="form-group">
                                            <label>Cena (€)</label>
                                            <InputNumber @bind-Value="newServiceRecord.Cost" class="form-input" placeholder="150.00" />
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label>Vykonané práce *</label>
                                        <InputTextArea @bind-Value="newServiceRecord.Description" class="form-textarea" 
                                                      placeholder="Podrobný popis vykonaných prác..." rows="3" />
                                        <ValidationMessage For="@(() => newServiceRecord.Description)" class="validation-error" />
                                    </div>

                                    <div class="form-group">
                                        <label>Použité náhradné diely</label>
                                        <InputText @bind-Value="newServiceRecord.PartsUsed" class="form-input" 
                                                  placeholder="Olej Castrol 5W30, Olejový filter Mann..." />
                                    </div>

                                    <div class="form-group">
                                        <label>Interné poznámky</label>
                                        <InputTextArea @bind-Value="newServiceRecord.Notes" class="form-textarea" 
                                                      placeholder="Odporúčania, pozorovania..." rows="2" />
                                    </div>

                                    @if (!string.IsNullOrEmpty(formMessage))
                                    {
                                        <div class="alert @(formSuccess ? "alert-success" : "alert-error")">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                @if (formSuccess)
                                                {
                                                    <polyline points="20 6 9 17 4 12"/>
                                                }
                                                else
                                                {
                                                    <circle cx="12" cy="12" r="10"/>
                                                    <line x1="15" y1="9" x2="9" y2="15"/>
                                                    <line x1="9" y1="9" x2="15" y2="15"/>
                                                }
                                            </svg>
                                            <span>@formMessage</span>
                                        </div>
                                    }

                                    <div class="form-actions">
                                        <button type="button" @onclick="ClearForm" class="btn-secondary">Vyčistiť</button>
                                        <button type="submit" class="btn-primary" disabled="@isLoading">
                                            @if (isLoading)
                                            {
                                                <span class="spinner-sm"></span>
                                                <span>Ukladám...</span>
                                            }
                                            else
                                            {
                                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="20 6 9 17 4 12"/>
                                                </svg>
                                                <span>Uložiť záznam</span>
                                            }
                                        </button>
                                    </div>
                                </EditForm>
                            </div>

                            @if (serviceRecords != null && serviceRecords.Any())
                            {
                                <div class="divider"></div>
                                <h3 style="margin: 16px 0;">História servisov</h3>
                                <div class="records-list">
                                    @foreach (var record in serviceRecords.OrderByDescending(r => r.ServiceDate).Take(5))
                                    {
                                        <div class="record-item compact">
                                            <div class="record-date small">
                                                <div class="date-day">@record.ServiceDate.Day</div>
                                                <div class="date-month">@record.ServiceDate.ToString("MMM")</div>
                                            </div>
                                            <div class="record-content">
                                                <div class="record-header">
                                                    <h4>@record.Vehicle.Brand @record.Vehicle.Model</h4>
                                                    <span class="record-km">@record.ServiceType</span>
                                                </div>
                                                <p class="record-description">@record.Description</p>
                                                <p class="record-meta">Servis: @record.CreatedBy.FullName</p>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            }
            else if (userRole == "admin")
            {
                <!-- ADMINISTRÁTOR -->
                <div class="welcome-section">
                    <h1>Administrátorský panel 👨‍💼</h1>
                    <p>Kompletný prehľad systému a používateľov</p>
                </div>

                <div class="stats-grid">
                    <div class="stat-card blue">
                        <div class="stat-icon">👥</div>
                        <div class="stat-content">
                            <div class="stat-number">@GetTotalUsers()</div>
                            <div class="stat-label">Celkovo používateľov</div>
                        </div>
                    </div>
                    <div class="stat-card green">
                        <div class="stat-icon">🚗</div>
                        <div class="stat-content">
                            <div class="stat-number">@GetTotalVehicles()</div>
                            <div class="stat-label">Registrovaných vozidiel</div>
                        </div>
                    </div>
                    <div class="stat-card purple">
                        <div class="stat-icon">📋</div>
                        <div class="stat-content">
                            <div class="stat-number">@GetTotalRecords()</div>
                            <div class="stat-label">Servisných záznamov</div>
                        </div>
                    </div>
                    <div class="stat-card orange">
                        <div class="stat-icon">🔧</div>
                        <div class="stat-content">
                            <div class="stat-number">@GetTotalServices()</div>
                            <div class="stat-label">Autoservisov</div>
                        </div>
                    </div>
                </div>

                <div class="admin-grid">
                    <!-- POUŽÍVATELIA -->
                    <div class="dashboard-card full-width">
                        <div class="card-header">
                            <div>
                                <h2>Prehľad používateľov</h2>
                                <p class="card-subtitle">Všetci registrovaní používatelia v systéme</p>
                            </div>
                        </div>
                        
                        @if (allUsers != null && allUsers.Any())
                        {
                            <div class="table-responsive">
                                <table class="modern-table">
                                    <thead>
                                        <tr>
                                            <th>Meno</th>
                                            <th>Email</th>
                                            <th>Rola</th>
                                            <th>Vozidlá</th>
                                            <th>Záznamy</th>
                                            <th>Registrácia</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var user in allUsers)
                                        {
                                            <tr>
                                                <td>
                                                    <div class="user-cell">
                                                        <div class="user-avatar-sm">@GetInitials(user.FirstName, user.LastName)</div>
                                                        <strong>@user.FullName</strong>
                                                    </div>
                                                </td>
                                                <td>@user.Email</td>
                                                <td>
                                                    <span class="role-badge @GetRoleBadgeClass(user.Role)">
                                                        @GetRoleName(user.Role)
                                                    </span>
                                                </td>
                                                <td>@user.OwnedVehicles.Count</td>
                                                <td>@user.CreatedServiceRecords.Count</td>
                                                <td>@user.CreatedAt.ToString("dd.MM.yyyy")</td>
                                                <td>
                                                    @if (user.IsActive)
                                                    {
                                                        <span class="status-badge active">Aktívny</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="status-badge inactive">Neaktívny</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>

                    <!-- VOZIDLÁ -->
                    <div class="dashboard-card">
                        <div class="card-header">
                            <div>
                                <h2>Všetky vozidlá</h2>
                                <p class="card-subtitle">Registrované vozidlá v systéme</p>
                            </div>
                        </div>
                        
                        @if (allVehicles != null && allVehicles.Any())
                        {
                            <div class="vehicle-grid">
                                @foreach (var vehicle in allVehicles.Take(6))
                                {
                                    <div class="vehicle-card" @onclick="() => SelectVehicle(vehicle.Id)">
                                        <div class="vehicle-icon">🚙</div>
                                        <div class="vehicle-info">
                                            <h3>@vehicle.Brand @vehicle.Model</h3>
                                            <div class="vehicle-details">
                                                <span class="detail-badge">@vehicle.Year</span>
                                                <span class="detail-badge">@vehicle.LicensePlate</span>
                                            </div>
                                            <p class="vehicle-vin">Majiteľ: @vehicle.Owner.FullName</p>
                                        </div>
                                        <div class="vehicle-status">
                                            <span class="status-text">@vehicle.ServiceRecords.Count záznamov</span>
                                        </div>
                                    </div>
                                }
                            </div>
                            @if (allVehicles.Count > 6)
                            {
                                <div style="text-align: center; margin-top: 16px;">
                                    <p class="text-muted">... a ďalších @(allVehicles.Count - 6) vozidiel</p>
                                </div>
                            }
                        }
                    </div>

                    <!-- NEDÁVNA AKTIVITA -->
                    <div class="dashboard-card">
                        <div class="card-header">
                            <div>
                                <h2>Nedávna aktivita</h2>
                                <p class="card-subtitle">Posledné servisné záznamy</p>
                            </div>
                        </div>
                        
                        @if (recentRecords != null && recentRecords.Any())
                        {
                            <div class="records-list">
                                @foreach (var record in recentRecords.Take(10))
                                {
                                    <div class="record-item compact">
                                        <div class="record-date small">
                                            <div class="date-day">@record.ServiceDate.Day</div>
                                            <div class="date-month">@record.ServiceDate.ToString("MMM")</div>
                                        </div>
                                        <div class="record-content">
                                            <div class="record-header">
                                                <h4>@record.Vehicle.Brand @record.Vehicle.Model</h4>
                                                <span class="record-km">@record.ServiceType</span>
                                            </div>
                                            <p class="record-description">@record.Description</p>
                                            <p class="record-meta">Servis: @record.CreatedBy.FullName</p>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}
</div>

