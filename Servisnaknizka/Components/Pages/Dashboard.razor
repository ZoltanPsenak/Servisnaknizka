    };

    private string GetVehicleServiceStatus(Vehicle vehicle)
    {
        var lastService = vehicle.ServiceRecords.MaxBy(sr => sr.ServiceDate);
        if (lastService == null) return "Bez servisu";
        var daysSinceService = (DateTime.Now - lastService.ServiceDate).Days;
        if (daysSinceService > 365) return "Potrebný servis";
        if (daysSinceService > 180) return "Blíži sa servis";
        return "V poriadku";
    }

    private string GetStatusClass(Vehicle vehicle)
    {
        var status = GetVehicleServiceStatus(vehicle);
        return status switch
        {
            "Potrebný servis" => "danger",
            "Blíži sa servis" => "warning",
            _ => "success"
        };
    }

    private int GetRecentServices()
    {
        if (vehicles == null) return 0;
        return vehicles.Sum(v => v.ServiceRecords.Count(sr => sr.ServiceDate >= DateTime.Now.AddMonths(-1)));
    }

