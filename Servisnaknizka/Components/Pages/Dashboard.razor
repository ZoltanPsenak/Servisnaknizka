    private async Task SaveVehicle()
    {
        if (string.IsNullOrWhiteSpace(vehicleFormVin) || vehicleFormVin.Length != 17)
        {
            vehicleFormMessage = "VIN musí mať presne 17 znakov.";
            vehicleFormSuccess = false;
            return;
        }
        if (string.IsNullOrWhiteSpace(vehicleFormBrand) || string.IsNullOrWhiteSpace(vehicleFormModel) || string.IsNullOrWhiteSpace(vehicleFormPlate))
        {
            vehicleFormMessage = "Vyplňte všetky povinné polia.";
            vehicleFormSuccess = false;
            return;
        }

        isLoading = true;
        vehicleFormMessage = string.Empty;
        StateHasChanged();

        try
        {
            if (editingVehicleId > 0)
            {
                var vehicle = await DbContext.Vehicles.FindAsync(editingVehicleId);
                if (vehicle != null && vehicle.OwnerId == currentUserId)
                {
                    vehicle.VIN = vehicleFormVin;
                    vehicle.Brand = vehicleFormBrand;
                    vehicle.Model = vehicleFormModel;
                    vehicle.Year = vehicleFormYear;
                    vehicle.LicensePlate = vehicleFormPlate;
                    vehicle.Color = string.IsNullOrWhiteSpace(vehicleFormColor) ? null : vehicleFormColor;
                    vehicle.EngineType = string.IsNullOrWhiteSpace(vehicleFormEngine) ? null : vehicleFormEngine;
                    vehicle.EnginePower = vehicleFormPower;
                    await DbContext.SaveChangesAsync();
                }
            }
            else
            {
                var vehicle = new Vehicle
                {
                    VIN = vehicleFormVin,
                    Brand = vehicleFormBrand,
                    Model = vehicleFormModel,
                    Year = vehicleFormYear,
                    LicensePlate = vehicleFormPlate,
                    Color = string.IsNullOrWhiteSpace(vehicleFormColor) ? null : vehicleFormColor,
                    EngineType = string.IsNullOrWhiteSpace(vehicleFormEngine) ? null : vehicleFormEngine,
                    EnginePower = vehicleFormPower,
                    OwnerId = currentUserId,
                    IsActive = true,
                    CreatedAt = DateTime.UtcNow
                };
                DbContext.Vehicles.Add(vehicle);
                await DbContext.SaveChangesAsync();
            }

            await LoadDataFromDatabase();
            showVehicleForm = false;
        }
        catch (Exception ex)
        {
            vehicleFormMessage = $"Chyba: {ex.Message}";
            vehicleFormSuccess = false;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    // ========== PERMISSION MANAGEMENT (OWNER) ==========

    private async Task GrantPermission()
    {
        permissionMessage = string.Empty;

        if (permissionVehicleId == 0)
        {
            permissionMessage = "Vyberte vozidlo.";
            permissionSuccess = false;
            return;
        }
        if (string.IsNullOrWhiteSpace(permissionServiceEmail))
        {
            permissionMessage = "Zadajte e-mail servisu.";
            permissionSuccess = false;
            return;
        }

        try
        {
            var serviceUser = await UserManager.FindByEmailAsync(permissionServiceEmail);
            if (serviceUser == null || serviceUser.Role != UserRole.Service)
            {
                permissionMessage = "Servis s týmto e-mailom neexistuje alebo nemá rolu Servis.";
                permissionSuccess = false;
                return;
            }

            var exists = await DbContext.Permissions.AnyAsync(p =>
                p.VehicleId == permissionVehicleId && p.ServiceId == serviceUser.Id && p.IsActive);
            if (exists)
            {
                permissionMessage = "Toto oprávnenie už existuje.";
                permissionSuccess = false;
                return;
            }

            var permission = new Permission
            {
                VehicleId = permissionVehicleId,
                ServiceId = serviceUser.Id,
                GrantedById = currentUserId,
                GrantedAt = DateTime.UtcNow,
                IsActive = true
            };
            DbContext.Permissions.Add(permission);
            await DbContext.SaveChangesAsync();

            permissionMessage = $"Oprávnenie pre {serviceUser.FullName} bolo úspešne pridelené!";
            permissionSuccess = true;
            permissionServiceEmail = string.Empty;
            permissionVehicleId = 0;

            await LoadDataFromDatabase();
        }
        catch (Exception ex)
        {
            permissionMessage = $"Chyba: {ex.Message}";
            permissionSuccess = false;
        }
        StateHasChanged();
    }

    private async Task RevokePermission(int permissionId)
    {
        try
        {
            var perm = await DbContext.Permissions.FindAsync(permissionId);
            if (perm != null)
            {
                perm.IsActive = false;
                await DbContext.SaveChangesAsync();
                await LoadDataFromDatabase();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error revoking permission: {ex.Message}");
        }
        StateHasChanged();
    }

    // ========== ADMIN: USER MANAGEMENT ==========

    private async Task AdminCreateUser()
    {
        adminUserMessage = string.Empty;

        if (userRole != "admin")
        {
            adminUserMessage = "Nemáte oprávnenie na túto akciu.";
            adminUserSuccess = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(adminNewFirstName) || string.IsNullOrWhiteSpace(adminNewLastName) ||
            string.IsNullOrWhiteSpace(adminNewEmail) || string.IsNullOrWhiteSpace(adminNewPassword))
        {
            adminUserMessage = "Vyplňte všetky povinné polia.";
            adminUserSuccess = false;
            return;
        }

        isLoading = true;
        StateHasChanged();

        try
        {
            var existingUser = await UserManager.FindByEmailAsync(adminNewEmail);
            if (existingUser != null)
            {
                adminUserMessage = "Používateľ s týmto e-mailom už existuje.";
                adminUserSuccess = false;
                isLoading = false;
                StateHasChanged();
                return;
            }

            var role = adminNewRole switch
            {
                "Service" => UserRole.Service,
                "Admin" => UserRole.Admin,
                _ => UserRole.Owner
            };

            var user = new User
            {
                FirstName = adminNewFirstName,
                LastName = adminNewLastName,
                UserName = adminNewEmail,
                Email = adminNewEmail,
                Role = role,
                EmailConfirmed = true,
                IsActive = true
            };

            var result = await UserManager.CreateAsync(user, adminNewPassword);
            if (result.Succeeded)
            {
                await UserManager.AddToRoleAsync(user, adminNewRole);
                await UserManager.AddClaimAsync(user, new Claim(ClaimTypes.Role, adminNewRole));

                adminUserMessage = $"Používateľ {user.FullName} bol úspešne vytvorený!";
                adminUserSuccess = true;
                adminNewFirstName = adminNewLastName = adminNewEmail = adminNewPassword = string.Empty;
                adminNewRole = "Owner";
                showAdminCreateUserForm = false;

                await LoadDataFromDatabase();
            }
            else
            {
                adminUserMessage = "Chyba: " + string.Join(", ", result.Errors.Select(e => e.Description));
                adminUserSuccess = false;
            }
        }
        catch (Exception ex)
        {
            adminUserMessage = $"Chyba: {ex.Message}";
            adminUserSuccess = false;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

